@{
    ViewData["Title"] = "Leave Management";
    var isAdminOrHR = User.IsInRole("Admin") || User.IsInRole("HRManager");
    var isEmployee = User.IsInRole("Employee");
}

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;">
    <div>
        <h1 class="page-title">Leave Management</h1>
        <p class="page-subtitle">@(isAdminOrHR ? "Review and manage leave requests" : "Apply for leave and check your balance")</p>
    </div>
    @if (isEmployee)
    {
        <button class="btn-primary" onclick="openApplyLeave()"><i class="fas fa-plus"></i> Apply for Leave</button>
    }
</div>

<!-- Leave Balance Cards (Nepal Standard) -->
<div class="leave-balance-grid" id="leaveBalanceGrid">
    <div class="leave-balance-card"><h4>Home Leave</h4><div class="balance-value" id="balHome">--</div><div class="balance-detail">1 day per 20 working days</div></div>
    <div class="leave-balance-card"><h4>Sick Leave</h4><div class="balance-value" id="balSick">--</div><div class="balance-detail">12 days / year</div></div>
    <div class="leave-balance-card"><h4>Maternity</h4><div class="balance-value" id="balMaternity">--</div><div class="balance-detail">98 days (60 paid)</div></div>
    <div class="leave-balance-card"><h4>Paternity</h4><div class="balance-value" id="balPaternity">--</div><div class="balance-detail">15 days</div></div>
    <div class="leave-balance-card"><h4>Mourning</h4><div class="balance-value" id="balMourning">--</div><div class="balance-detail">13 days</div></div>
    <div class="leave-balance-card"><h4>Public Holidays</h4><div class="balance-value" id="balPublic">--</div><div class="balance-detail">13 days (14 for women)</div></div>
</div>

<!-- Tabs -->
<div class="tabs">
    <button class="tab-btn active" onclick="switchLeaveTab(this,'all')">All Requests</button>
    <button class="tab-btn" onclick="switchLeaveTab(this,'pending')">Pending</button>
    <button class="tab-btn" onclick="switchLeaveTab(this,'approved')">Approved</button>
    <button class="tab-btn" onclick="switchLeaveTab(this,'rejected')">Rejected</button>
</div>

<!-- Leave Requests Table -->
<div class="table-container">
    <div class="table-header">
        <div class="filter-bar">
            <input type="text" class="form-control" placeholder="Search..." id="searchLeave" onkeyup="filterLeaves()" />
            <select class="form-select" id="leaveTypeFilter" onchange="filterLeaves()">
                <option value="">All Types</option>
                <option value="Home">Home Leave</option>
                <option value="Sick">Sick Leave</option>
                <option value="Maternity">Maternity</option>
                <option value="Paternity">Paternity</option>
                <option value="Mourning">Mourning</option>
            </select>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                @if (isAdminOrHR) { <th>Employee</th> }
                <th>Leave Type</th>
                <th>From</th>
                <th>To</th>
                <th>Days</th>
                <th>Reason</th>
                <th>Status</th>
                @if (isAdminOrHR) { <th>Actions</th> }
            </tr>
        </thead>
        <tbody id="leaveTableBody">
            <tr><td colspan="8" class="text-center" style="padding:2rem;">Loading...</td></tr>
        </tbody>
    </table>
</div>

<!-- Apply Leave Modal -->
<div class="modal-overlay" id="applyLeaveModal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Apply for Leave</h3>
            <button class="modal-close" onclick="closeModal('applyLeaveModal')">&times;</button>
        </div>
        <div class="modal-body">
            <div id="leaveError" style="display:none;background:#fef2f2;border:1px solid #fecaca;border-radius:var(--radius);padding:0.75rem;margin-bottom:1rem;">
                <p style="font-size:0.8rem;color:#dc2626;margin:0;" id="leaveErrorText"></p>
            </div>
            <form id="leaveForm">
                <div class="form-group">
                    <label class="form-label">Leave Type *</label>
                    <select class="form-select" id="leaveType" required onchange="checkBalance()">
                        <option value="">Select Type</option>
                        <option value="0">Home Leave</option>
                        <option value="1">Sick Leave</option>
                        <option value="2">Maternity Leave</option>
                        <option value="3">Paternity Leave</option>
                        <option value="4">Mourning Leave</option>
                    </select>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                    <div class="form-group"><label class="form-label">From Date *</label><input type="date" class="form-control" id="leaveFrom" required onchange="calcDays()" /></div>
                    <div class="form-group"><label class="form-label">To Date *</label><input type="date" class="form-control" id="leaveTo" required onchange="calcDays()" /></div>
                </div>
                <div class="form-group">
                    <label class="form-label">Number of Days</label>
                    <input type="number" class="form-control" id="leaveDays" readonly />
                </div>
                <div class="form-group">
                    <label class="form-label">Reason *</label>
                    <textarea class="form-control" id="leaveReason" rows="3" required placeholder="Provide reason for leave"></textarea>
                </div>
                <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:var(--radius);padding:0.75rem;">
                    <p style="font-size:0.8rem;color:#1e40af;margin:0;"><i class="fas fa-info-circle"></i> Your supervisor will be notified. HR will approve/reject the request. You must have sufficient leave balance to apply.</p>
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" onclick="closeModal('applyLeaveModal')">Cancel</button>
            <button class="btn-primary" id="submitLeaveBtn" onclick="submitLeave()"><i class="fas fa-paper-plane"></i> Submit Request</button>
        </div>
    </div>
</div>

<!-- Approve/Reject Modal -->
<div class="modal-overlay" id="actionLeaveModal">
    <div class="modal-box">
        <div class="modal-header">
            <h3 id="actionTitle">Leave Action</h3>
            <button class="modal-close" onclick="closeModal('actionLeaveModal')">&times;</button>
        </div>
        <div class="modal-body">
            <div id="leaveDetail"></div>
            <div class="form-group mt-2">
                <label class="form-label">Remarks</label>
                <textarea class="form-control" id="actionRemarks" rows="2" placeholder="Optional remarks"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" onclick="closeModal('actionLeaveModal')">Cancel</button>
            <button class="btn-danger" id="rejectBtn" onclick="rejectLeave()"><i class="fas fa-times"></i> Reject</button>
            <button class="btn-success" id="approveBtn" onclick="approveLeave()"><i class="fas fa-check"></i> Approve</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
var currentLeaveId = null;
var leaveBalance = {};
var currentTab = 'all';
var isAdminOrHR = @(isAdminOrHR ? "true" : "false");
var currentEmployeeId = null;

document.addEventListener('DOMContentLoaded', function() {
    // Get current employee ID first, then load data
    fetch('/api/employee').then(r => r.json()).then(data => {
        if (data && data.length > 0) {
            currentEmployeeId = data[0].id;
        }
        loadLeaveBalance();
        loadLeaveRequests();
    }).catch(() => {
        loadLeaveRequests();
    });
});

function loadLeaveBalance() {
    if (!currentEmployeeId) return;
    // Backend: GET /api/leave/balance/{employeeId}
    fetch('/api/leave/balance/' + currentEmployeeId).then(r => {
        if (!r.ok) throw new Error('Failed');
        return r.json();
    }).then(data => {
        leaveBalance = data;
        document.getElementById('balHome').textContent = (data.homeLeaveBalance || 0) + ' days';
        document.getElementById('balSick').textContent = (data.sickLeaveBalance || 0) + ' days';
        document.getElementById('balMaternity').textContent = (data.maternityLeaveBalance || 0) + ' days';
        document.getElementById('balPaternity').textContent = (data.paternityLeaveBalance || 0) + ' days';
        document.getElementById('balMourning').textContent = (data.mourningLeaveBalance || 0) + ' days';
        document.getElementById('balPublic').textContent = (data.publicHolidayBalance || 0) + ' days';
    }).catch(() => {});
}

function loadLeaveRequests() {
    var url;
    if (isAdminOrHR) {
        // Admin/HR see pending requests
        url = '/api/leave/pending';
    } else if (currentEmployeeId) {
        // Employee sees their own requests: GET /api/leave/employee/{employeeId}
        url = '/api/leave/employee/' + currentEmployeeId;
    } else {
        document.getElementById('leaveTableBody').innerHTML = '<tr><td colspan="8" class="text-center">No employee profile found</td></tr>';
        return;
    }
    fetch(url).then(r => {
        if (!r.ok) throw new Error('Failed');
        return r.json();
    }).then(data => {
        renderLeaves(data);
    }).catch(() => {
        document.getElementById('leaveTableBody').innerHTML = '<tr><td colspan="8" class="text-center">Failed to load</td></tr>';
    });
}

function renderLeaves(data) {
    var tbody = document.getElementById('leaveTableBody');
    if (!data || data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8"><div class="empty-state"><i class="fas fa-calendar-minus"></i><h4>No leave requests</h4></div></td></tr>';
        return;
    }
    var types = ['Home', 'Sick', 'Maternity', 'Paternity', 'Mourning', 'PublicHoliday'];
    var statuses = ['Pending', 'Approved', 'Rejected', 'Cancelled'];
    tbody.innerHTML = data.map(l => {
        var type = types[l.leaveType] || 'Unknown';
        var status = statuses[l.status] || 'Unknown';
        var badge = l.status === 0 ? 'badge-warning' : l.status === 1 ? 'badge-success' : 'badge-danger';
        return `<tr data-status="${status.toLowerCase()}" data-type="${type}">
            ${isAdminOrHR ? '<td>' + (l.employeeName || 'Employee #' + l.employeeId) + '</td>' : ''}
            <td>${type}</td>
            <td>${l.startDate ? new Date(l.startDate).toLocaleDateString() : '-'}</td>
            <td>${l.endDate ? new Date(l.endDate).toLocaleDateString() : '-'}</td>
            <td>${l.numberOfDays || '-'}</td>
            <td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${l.reason || '-'}</td>
            <td><span class="badge-status ${badge}">${status}</span></td>
            ${isAdminOrHR && l.status === 0 ? '<td><div class="d-flex gap-1"><button class="btn-icon" title="Review" onclick="reviewLeave(' + l.id + ')"><i class="fas fa-gavel"></i></button></div></td>' : '<td></td>'}
        </tr>`;
    }).join('');
}

function switchLeaveTab(btn, tab) {
    btn.parentElement.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentTab = tab;
    document.querySelectorAll('#leaveTableBody tr[data-status]').forEach(r => {
        r.style.display = (tab === 'all' || r.dataset.status === tab) ? '' : 'none';
    });
}

function filterLeaves() {
    var s = document.getElementById('searchLeave').value.toLowerCase();
    var t = document.getElementById('leaveTypeFilter').value;
    document.querySelectorAll('#leaveTableBody tr[data-status]').forEach(r => {
        var matchTab = (currentTab === 'all' || r.dataset.status === currentTab);
        var matchType = (!t || r.dataset.type === t);
        var matchSearch = (!s || r.textContent.toLowerCase().includes(s));
        r.style.display = (matchTab && matchType && matchSearch) ? '' : 'none';
    });
}

function openApplyLeave() {
    document.getElementById('leaveForm').reset();
    document.getElementById('leaveError').style.display = 'none';
    document.getElementById('applyLeaveModal').classList.add('active');
}

function calcDays() {
    var from = document.getElementById('leaveFrom').value;
    var to = document.getElementById('leaveTo').value;
    if (from && to) {
        var diff = Math.ceil((new Date(to) - new Date(from)) / (1000 * 60 * 60 * 24)) + 1;
        document.getElementById('leaveDays').value = diff > 0 ? diff : 0;
    }
}

function checkBalance() {
    var type = parseInt(document.getElementById('leaveType').value);
    var balMap = { 0: 'homeLeaveBalance', 1: 'sickLeaveBalance', 2: 'maternityLeaveBalance', 3: 'paternityLeaveBalance', 4: 'mourningLeaveBalance' };
    var bal = leaveBalance[balMap[type]] || 0;
    if (bal <= 0) {
        document.getElementById('leaveError').style.display = 'block';
        document.getElementById('leaveErrorText').textContent = 'You do not have sufficient balance for this leave type. Balance: ' + bal + ' days.';
        document.getElementById('submitLeaveBtn').disabled = true;
    } else {
        document.getElementById('leaveError').style.display = 'none';
        document.getElementById('submitLeaveBtn').disabled = false;
    }
}

function submitLeave() {
    var type = document.getElementById('leaveType').value;
    var from = document.getElementById('leaveFrom').value;
    var to = document.getElementById('leaveTo').value;
    var days = document.getElementById('leaveDays').value;
    var reason = document.getElementById('leaveReason').value;
    if (!type || !from || !to || !reason) { alert('Please fill all required fields.'); return; }
    if (!currentEmployeeId) { alert('Employee profile not found.'); return; }

    // Backend: POST /api/leave/request with LeaveRequestViewModel
    fetch('/api/leave/request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            employeeId: currentEmployeeId,
            leaveType: parseInt(type),
            startDate: from,
            endDate: to,
            numberOfDays: parseInt(days),
            reason: reason
        })
    }).then(r => {
        if (r.ok) { closeModal('applyLeaveModal'); loadLeaveRequests(); loadLeaveBalance(); alert('Leave request submitted! Your supervisor and HR have been notified.'); }
        else r.text().then(t => alert('Error: ' + t));
    }).catch(() => alert('Failed to submit'));
}

function reviewLeave(id) {
    currentLeaveId = id;
    document.getElementById('actionLeaveModal').classList.add('active');
}

function approveLeave() {
    if (!currentLeaveId) return;
    var remarks = document.getElementById('actionRemarks').value;
    // Backend: POST /api/leave/approve with LeaveApprovalViewModel { LeaveRequestId, Remarks }
    fetch('/api/leave/approve', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ leaveRequestId: currentLeaveId, remarks: remarks })
    }).then(r => {
        if (r.ok) { closeModal('actionLeaveModal'); loadLeaveRequests(); alert('Leave approved!'); }
        else alert('Failed to approve');
    }).catch(() => alert('Error'));
}

function rejectLeave() {
    if (!currentLeaveId) return;
    var remarks = document.getElementById('actionRemarks').value;
    if (!remarks) { alert('Please provide a reason for rejection.'); return; }
    // Backend: POST /api/leave/reject/{id}?reason=...
    fetch('/api/leave/reject/' + currentLeaveId + '?reason=' + encodeURIComponent(remarks), {
        method: 'POST'
    }).then(r => {
        if (r.ok) { closeModal('actionLeaveModal'); loadLeaveRequests(); alert('Leave rejected.'); }
        else alert('Failed to reject');
    }).catch(() => alert('Error'));
}

function closeModal(id) { document.getElementById(id).classList.remove('active'); }
</script>
}