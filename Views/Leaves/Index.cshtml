@{
    ViewData["Title"] = "Leave Requests";
}

<div class="page-header">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h1 class="page-title">Leave Requests</h1>
            <p class="page-subtitle">Manage and track employee leave requests</p>
        </div>
        <button class="btn btn-primary" onclick="openAddLeaveModal()">
            <i class="fas fa-plus"></i> New Leave Request
        </button>
    </div>
</div>

<!-- Leave Statistics -->
<div class="dashboard-grid" style="margin-bottom: 2rem;">
    <div class="kpi-card">
        <div class="kpi-icon" style="background: linear-gradient(135deg, #10b98115 0%, #059e0a15 100%); color: #16a34a;">
            <i class="fas fa-check-circle"></i>
        </div>
        <h5 class="kpi-label">Approved</h5>
        <div class="kpi-value" id="stat-approved">0</div>
        <div class="stat-change positive">Approved requests</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background: linear-gradient(135deg, #f59e0b15 0%, #d9790015 100%); color: #f59e0b;">
            <i class="fas fa-hourglass-half"></i>
        </div>
        <h5 class="kpi-label">Pending</h5>
        <div class="kpi-value" id="stat-pending">0</div>
        <div class="stat-change">Waiting approval</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background: linear-gradient(135deg, #ef444415 0%, #dc263015 100%); color: #ef4444;">
            <i class="fas fa-times-circle"></i>
        </div>
        <h5 class="kpi-label">Rejected</h5>
        <div class="kpi-value" id="stat-rejected">0</div>
        <div class="stat-change negative">Denied requests</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background: linear-gradient(135deg, #2563eb15 0%, #0ea5e915 100%); color: #2563eb;">
            <i class="fas fa-calendar-alt"></i>
        </div>
        <h5 class="kpi-label">Total</h5>
        <div class="kpi-value" id="stat-total">0</div>
        <div class="stat-change">All requests</div>
    </div>
</div>

<!-- Tabs for Different Views -->
<div class="card">
    <div class="card-header">
        <ul class="nav nav-tabs" style="border: none; margin-bottom: 0;">
            <li class="nav-item">
                <a class="nav-link active" onclick="filterLeaves('all')" style="cursor:pointer; color: #6b7280; border: none;">
                    <i class="fas fa-list me-2"></i>All Requests
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" onclick="filterLeaves('Pending')" style="cursor:pointer; color: #6b7280; border: none;">
                    <i class="fas fa-hourglass-half me-2"></i>Pending (<span id="tab-pending">0</span>)
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" onclick="filterLeaves('Approved')" style="cursor:pointer; color: #6b7280; border: none;">
                    <i class="fas fa-check me-2"></i>Approved (<span id="tab-approved">0</span>)
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" onclick="filterLeaves('Rejected')" style="cursor:pointer; color: #6b7280; border: none;">
                    <i class="fas fa-times me-2"></i>Rejected (<span id="tab-rejected">0</span>)
                </a>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <div id="leaves-container">
            <div style="text-align:center; padding:3rem; color: #6b7280;">
                <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
                <p style="margin-top:1rem;">Loading leave requests...</p>
            </div>
        </div>
    </div>
</div>

<!-- Add Leave Request Modal -->
<div class="modal-overlay" id="leaveModal">
    <div class="modal-box">
        <div class="modal-header">
            <h5 style="margin:0;">New Leave Request</h5>
            <button onclick="closeLeaveModal()" style="background:none;border:none;font-size:1.5rem;cursor:pointer;">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group" style="margin-bottom:1rem;" id="employee-select-group">
                <label>Employee <span style="color:red;">*</span></label>
                <select class="form-control" id="leaveEmployeeId">
                    <option value="">Select Employee</option>
                </select>
            </div>
            <div class="form-group" style="margin-bottom:1rem;">
                <label>From Date <span style="color:red;">*</span></label>
                <input type="date" class="form-control" id="leaveFromDate" required>
            </div>
            <div class="form-group" style="margin-bottom:1rem;">
                <label>To Date <span style="color:red;">*</span></label>
                <input type="date" class="form-control" id="leaveToDate" required>
            </div>
            <div class="form-group" style="margin-bottom:1rem;">
                <label>Reason <span style="color:red;">*</span></label>
                <textarea class="form-control" id="leaveReason" rows="3" placeholder="Enter reason for leave" required></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline-secondary" onclick="closeLeaveModal()">Cancel</button>
            <button class="btn btn-primary" onclick="submitLeave()">Submit Request</button>
        </div>
    </div>
</div>

