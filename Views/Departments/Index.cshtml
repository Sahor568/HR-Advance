@{
    ViewData["Title"] = "Departments";
    var isAdminOrHR = User.IsInRole("Admin") || User.IsInRole("HRManager");
}

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;">
    <div>
        <h1 class="page-title">Departments & Positions</h1>
        <p class="page-subtitle">Manage organizational structure</p>
    </div>
    @if (isAdminOrHR)
    {
        <button class="btn-primary" onclick="openAddDept()"><i class="fas fa-plus"></i> Add Department</button>
    }
</div>

<!-- Department Cards -->
<div id="deptGrid" class="kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr));margin-bottom:1.5rem;"></div>

<!-- Department Table -->
<div class="table-container">
    <div class="table-header">
        <h3 style="font-size:1rem;font-weight:600;margin:0;">All Departments</h3>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Department</th>
                <th>Code</th>
                <th>Head</th>
                <th>Employees</th>
                <th>Status</th>
                @if (isAdminOrHR) { <th>Actions</th> }
            </tr>
        </thead>
        <tbody id="deptBody">
            <tr><td colspan="6" class="text-center" style="padding:2rem;">Loading...</td></tr>
        </tbody>
    </table>
</div>

<!-- Add/Edit Department Modal -->
@if (isAdminOrHR)
{
<div class="modal-overlay" id="deptModal">
    <div class="modal-box">
        <div class="modal-header">
            <h3 id="deptModalTitle">Add Department</h3>
            <button class="modal-close" onclick="closeModal('deptModal')">&times;</button>
        </div>
        <div class="modal-body">
            <form id="deptForm">
                <input type="hidden" id="deptId" />
                <div class="form-group"><label class="form-label">Department Name *</label><input type="text" class="form-control" id="deptName" required /></div>
                <div class="form-group"><label class="form-label">Code *</label><input type="text" class="form-control" id="deptCode" required placeholder="e.g. IT, HR, FIN" /></div>
                <div class="form-group"><label class="form-label">Department Head</label><input type="text" class="form-control" id="deptHead" /></div>
                <div class="form-group"><label class="form-label">Description</label><textarea class="form-control" id="deptDesc" rows="2"></textarea></div>
                <div class="form-group">
                    <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.85rem;cursor:pointer;">
                        <input type="checkbox" id="deptActive" checked /> Active
                    </label>
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" onclick="closeModal('deptModal')">Cancel</button>
            <button class="btn-primary" onclick="saveDept()"><i class="fas fa-save"></i> Save</button>
        </div>
    </div>
</div>
}

@section Scripts {
<script>
var isAdminOrHR = @(isAdminOrHR ? "true" : "false");
document.addEventListener('DOMContentLoaded', loadDepartments);

function loadDepartments() {
    fetch('/api/departments').then(r=>r.json()).then(data => {
        renderDeptCards(data);
        renderDeptTable(data);
    }).catch(()=>{ document.getElementById('deptBody').innerHTML='<tr><td colspan="6" class="text-center">Failed to load</td></tr>'; });
}

function renderDeptCards(data) {
    var grid=document.getElementById('deptGrid');
    if(!data||data.length===0){grid.innerHTML='';return;}
    var colors=['blue','green','purple','orange','teal','red'];
    grid.innerHTML=data.slice(0,6).map((d,i)=>`
        <div class="kpi-card">
            <div class="kpi-icon ${colors[i%colors.length]}"><i class="fas fa-building"></i></div>
            <div class="kpi-info">
                <div class="kpi-value" style="font-size:1.1rem;">${d.name}</div>
                <div class="kpi-label">${d.employeeCount||0} employees | Head: ${d.departmentHead||'N/A'}</div>
            </div>
        </div>
    `).join('');
}

function renderDeptTable(data) {
    var tbody=document.getElementById('deptBody');
    if(!data||data.length===0){tbody.innerHTML='<tr><td colspan="6"><div class="empty-state"><i class="fas fa-sitemap"></i><h4>No departments</h4></div></td></tr>';return;}
    tbody.innerHTML=data.map(d=>`
        <tr>
            <td style="font-weight:500;">${d.name}</td>
            <td><span class="badge-status badge-secondary">${d.code||'-'}</span></td>
            <td>${d.departmentHead||'-'}</td>
            <td>${d.employeeCount||0}</td>
            <td><span class="badge-status ${d.isActive?'badge-success':'badge-danger'}">${d.isActive?'Active':'Inactive'}</span></td>
            ${isAdminOrHR?`<td><div class="d-flex gap-1"><button class="btn-icon" title="Edit" onclick="editDept(${d.id})"><i class="fas fa-edit"></i></button><button class="btn-icon" title="Delete" onclick="deleteDept(${d.id})"><i class="fas fa-trash"></i></button></div></td>`:'<td></td>'}
        </tr>
    `).join('');
}

function openAddDept() {
    document.getElementById('deptModalTitle').textContent='Add Department';
    document.getElementById('deptForm').reset();
    document.getElementById('deptId').value='';
    document.getElementById('deptActive').checked=true;
    document.getElementById('deptModal').classList.add('active');
}

function editDept(id) {
    fetch(`/api/departments/${id}`).then(r=>r.json()).then(d=>{
        console.log('Department data received:', d);
        document.getElementById('deptModalTitle').textContent='Edit Department';
        // Try both 'id' and 'Id' property names (camelCase vs PascalCase)
        var departmentId = d.id !== undefined ? d.id : d.Id;
        console.log('Department ID:', departmentId);
        document.getElementById('deptId').value=departmentId;
        document.getElementById('deptName').value=d.name||'';
        document.getElementById('deptCode').value=d.code||'';
        document.getElementById('deptHead').value=d.departmentHead||'';
        document.getElementById('deptDesc').value=d.description||'';
        document.getElementById('deptActive').checked=d.isActive!==false;
        document.getElementById('deptModal').classList.add('active');
    }).catch((err)=>{
        console.error('Failed to fetch department:', err);
        alert('Failed to load department details');
    });
}

function saveDept() {
    var idValue = document.getElementById('deptId').value;
    console.log('Saving department, ID value:', idValue);
    
    // Validate required fields
    var name = document.getElementById('deptName').value.trim();
    var code = document.getElementById('deptCode').value.trim();
    if (!name) {
        alert('Department Name is required');
        return;
    }
    if (!code) {
        alert('Department Code is required');
        return;
    }
    
    var body = {
        name: name,
        code: code,
        departmentHead: document.getElementById('deptHead').value,
        description: document.getElementById('deptDesc').value,
        isActive: document.getElementById('deptActive').checked
    };
    
    var url, method;
    var idNum = parseInt(idValue);
    
    if (idValue && !isNaN(idNum) && idNum > 0) {
        // Update existing department
        url = `/api/departments/${idNum}`;
        method = 'PUT';
        // Include ID in request body - try both casings
        body.Id = idNum;  // PascalCase
        body.id = idNum;  // camelCase
        console.log('Updating department with ID:', idNum);
    } else {
        // Create new department
        url = '/api/departments';
        method = 'POST';
        console.log('Creating new department');
    }
    
    console.log('URL:', url, 'Method:', method);
    console.log('Request body:', body);
    console.log('Request body JSON:', JSON.stringify(body));
    
    fetch(url, {
        method: method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
    }).then(r => {
        console.log('Response status:', r.status, r.statusText);
        if (r.ok) {
            closeModal('deptModal');
            loadDepartments();
            alert('Department saved successfully!');
        } else {
            console.error('Server responded with error status:', r.status);
            // Try to parse as JSON for validation errors
            r.json().then(data => {
                console.error('Error response JSON:', data);
                if (data.errors) {
                    // ModelState errors
                    var errorMsg = 'Validation errors:\n';
                    for (var key in data.errors) {
                        errorMsg += key + ': ' + data.errors[key].join(', ') + '\n';
                    }
                    alert(errorMsg);
                } else if (data.title) {
                    alert('Error: ' + data.title);
                } else if (typeof data === 'string') {
                    alert('Error: ' + data);
                } else {
                    alert('Error: ' + JSON.stringify(data));
                }
            }).catch(() => {
                // Not JSON, try text
                r.text().then(t => {
                    console.error('Error response text:', t);
                    alert('Error: ' + t);
                });
            });
        }
    }).catch(err => {
        console.error('Fetch error:', err);
        alert('Failed to save department: ' + err.message);
    });
}

function deleteDept(id) {
    if(!confirm('Delete this department?'))return;
    fetch(`/api/departments/${id}`,{method:'DELETE'}).then(r=>{if(r.ok)loadDepartments();else alert('Failed');}).catch(()=>alert('Error'));
}

function closeModal(id){document.getElementById(id).classList.remove('active');}
</script>
}