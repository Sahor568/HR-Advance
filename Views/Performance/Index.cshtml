@model IEnumerable<HR_Management_System.Models.Performance.PerformanceReview>

@{
    ViewData["Title"] = "Performance Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3 mb-0">Performance Management</h1>
            <p class="text-muted">Manage employee performance reviews, goals, and feedback</p>
        </div>
        <div class="col-auto">
            <a href="/Performance/Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> New Review
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">Performance Reviews</h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Employee ID</th>
                                <th>Review Period</th>
                                <th>Review Type</th>
                                <th>Status</th>
                                <th>Review Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var review in Model)
                            {
                                <tr>
                                    <td>@review.EmployeeId</td>
                                    <td>@review.ReviewStartDate.ToString("MMM yyyy") - @review.ReviewEndDate.ToString("MMM yyyy")</td>
                                    <td>
                                        <span class="badge bg-secondary">@review.ReviewType</span>
                                    </td>
                                    <td>
                                        @{
                                            var statusClass = review.Status == HR_Management_System.Models.Performance.ReviewStatus.Finalized ? "success" :
                                            review.Status == HR_Management_System.Models.Performance.ReviewStatus.Approved ? "success" :
                                            review.Status == HR_Management_System.Models.Performance.ReviewStatus.Draft ? "secondary" :
                                            review.Status == HR_Management_System.Models.Performance.ReviewStatus.SelfReviewPending ? "warning" :
                                            review.Status == HR_Management_System.Models.Performance.ReviewStatus.ManagerReviewPending ? "warning" :
                                            review.Status == HR_Management_System.Models.Performance.ReviewStatus.HRReviewPending ? "warning" :
                                            review.Status == HR_Management_System.Models.Performance.ReviewStatus.DiscussionPending ? "info" :
                                            review.Status == HR_Management_System.Models.Performance.ReviewStatus.Rejected ? "danger" : "secondary";
                                            var statusText = review.Status.ToString();
                                        }
                                        <span class="badge bg-@statusClass">
                                            @statusText
                                        </span>
                                    </td>
                                    <td>@review.ReviewDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <a href="/Performance/Details/@review.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-chart-line fa-3x text-muted mb-3"></i>
                    <h5>No Performance Reviews Found</h5>
                    <p class="text-muted">Start by creating a new performance review</p>
                    <a href="/Performance/Create" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Create First Review
                    </a>
                </div>
            }
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Performance Goals</h5>
                </div>
                <div class="card-body">
                    <p class="card-text">Set and track employee performance goals and KRAs (Key Result Areas).</p>
                    <a href="/Performance/Goals" class="btn btn-outline-primary">Manage Goals</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Feedback & Appraisals</h5>
                </div>
                <div class="card-body">
                    <p class="card-text">Provide continuous feedback and conduct performance appraisals.</p>
                    <a href="/Performance/Feedback" class="btn btn-outline-primary">Give Feedback</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('table').DataTable({
                responsive: true,
                pageLength: 10
            });
        });
    </script>
}