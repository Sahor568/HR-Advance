@{
    ViewData["Title"] = "My Profile";
}

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-user me-2"></i>My Profile</h1>
    <p class="page-subtitle">View your personal and employment information</p>
</div>

<div style="display: grid; grid-template-columns: 350px 1fr; gap: 2rem;">
    <!-- Profile Card -->
    <div class="card" style="height: fit-content;">
        <div class="card-body text-center" style="padding: 2rem;">
            <div style="width: 120px; height: 120px; border-radius: 50%; background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%); color: white; display: flex; align-items: center; justify-content: center; font-size: 3rem; margin: 0 auto 1.5rem;">
                <i class="fas fa-user"></i>
            </div>
            <h4 id="profile-name" style="margin-bottom: 0.5rem;">John Doe</h4>
            <p id="profile-role" style="color: #6b7280; margin-bottom: 1rem;">Software Engineer</p>
            <div style="background: #f3f4f6; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; text-align: left;">
                <p style="margin: 0.5rem 0; font-size: 0.85rem; color: #6b7280;">
                    <strong>Department:</strong><br>
                    <span id="profile-department">Engineering</span>
                </p>
                <p style="margin: 0.5rem 0; font-size: 0.85rem; color: #6b7280;">
                    <strong>Employee ID:</strong><br>
                    <span id="profile-empid">--</span>
                </p>
                <p style="margin: 0.5rem 0; font-size: 0.85rem; color: #6b7280;">
                    <strong>Status:</strong><br>
                    <span id="profile-status" style="color: #16a34a; font-weight: 600;">Active</span>
                </p>
            </div>
            <button class="btn btn-primary w-100" onclick="alert('Contact HR to update profile information')">
                <i class="fas fa-edit"></i> Edit Profile
            </button>
        </div>
    </div>

    <!-- Profile Details Tabs -->
    <div>
        <div class="card">
            <div class="card-header">
                <ul class="nav nav-tabs" style="border: none; margin-bottom: 0;">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#personal" style="color: #6b7280; border: none;">
                            <i class="fas fa-address-card me-2"></i>Personal Info
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#employment" style="color: #6b7280; border: none;">
                            <i class="fas fa-briefcase me-2"></i>Employment
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#leaves" style="color: #6b7280; border: none;">
                            <i class="fas fa-calendar-alt me-2"></i>My Leaves
                        </a>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                <div class="tab-content">
                    <!-- Personal Info Tab -->
                    <div class="tab-pane fade show active" id="personal">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">First Name</label>
                                <input type="text" class="form-control" id="edit-firstName" placeholder="First Name" readonly style="background-color: #f3f4f6;">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Last Name</label>
                                <input type="text" class="form-control" id="edit-lastName" placeholder="Last Name" readonly style="background-color: #f3f4f6;">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-control" id="edit-email" placeholder="Email" readonly style="background-color: #f3f4f6;">
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Phone Number</label>
                                <input type="tel" class="form-control" id="edit-phone" placeholder="Phone" readonly style="background-color: #f3f4f6;">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Date of Birth</label>
                                <input type="date" class="form-control" id="edit-dob" readonly style="background-color: #f3f4f6;">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Address</label>
                            <textarea class="form-control" rows="3" id="edit-address" readonly style="background-color: #f3f4f6;"></textarea>
                        </div>
                        <div class="alert alert-info mb-0">
                            <i class="fas fa-info-circle me-2"></i>
                            Contact HR to update personal information.
                        </div>
                    </div>

                    <!-- Employment Tab -->
                    <div class="tab-pane fade" id="employment">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Employee ID</label>
                                <input type="text" class="form-control" id="emp-id" readonly style="background-color: #f3f4f6;">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Position</label>
                                <input type="text" class="form-control" id="emp-position" readonly style="background-color: #f3f4f6;">
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Department</label>
                                <input type="text" class="form-control" id="emp-department" readonly style="background-color: #f3f4f6;">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Hire Date</label>
                                <input type="date" class="form-control" id="emp-hiredate" readonly style="background-color: #f3f4f6;">
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Supervisor</label>
                                <input type="text" class="form-control" id="emp-supervisor" readonly style="background-color: #f3f4f6;">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Employment Status</label>
                                <input type="text" class="form-control" id="emp-status" readonly style="background-color: #f3f4f6;">
                            </div>
                        </div>
                        <div class="alert alert-info mb-0">
                            <i class="fas fa-info-circle me-2"></i>
                            Employment details are managed by HR. Contact HR for any changes.
                        </div>
                    </div>

                    <!-- Leaves Tab -->
                    <div class="tab-pane fade" id="leaves">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <div style="text-align: center; padding: 1.5rem; background: #f3f4f6; border-radius: 8px;">
                                    <div style="font-size: 2rem; font-weight: 700; color: #2563eb;" id="annual-leave">--</div>
                                    <div style="color: #6b7280; font-size: 0.85rem; margin-top: 0.5rem;">Annual Leave</div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div style="text-align: center; padding: 1.5rem; background: #f3f4f6; border-radius: 8px;">
                                    <div style="font-size: 2rem; font-weight: 700; color: #f59e0b;" id="sick-leave">--</div>
                                    <div style="color: #6b7280; font-size: 0.85rem; margin-top: 0.5rem;">Sick Leave</div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div style="text-align: center; padding: 1.5rem; background: #f3f4f6; border-radius: 8px;">
                                    <div style="font-size: 2rem; font-weight: 700; color: #16a34a;" id="casual-leave">--</div>
                                    <div style="color: #6b7280; font-size: 0.85rem; margin-top: 0.5rem;">Casual Leave</div>
                                </div>
                            </div>
                        </div>
                        <div style="margin-top: 1.5rem;">
                            <h6 style="margin-bottom: 1rem;">Leave History</h6>
                            <div id="leave-history" style="max-height: 300px; overflow-y: auto;">
                                <div class="text-center text-muted py-3">
                                    <i class="fas fa-spinner fa-spin me-2"></i>Loading...
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    loadProfileData();
});

function loadProfileData() {
    // Simulate loading profile data
    setTimeout(() => {
        const profileData = {
            firstName: 'John',
            lastName: 'Doe',
            email: 'john.doe@hrsystem.com',
            phone: '+975-1-123-4567',
            dob: '1995-06-15',
            address: 'Thimphu, Bhutan',
            employeeId: 'EMP001',
            position: 'Senior Software Engineer',
            department: 'Engineering',
            hireDate: '2021-01-15',
            status: 'Permanent',
            supervisor: 'Jane Smith',
            annualLeave: '18 days',
            sickLeave: '10 days',
            casualLeave: '8 days'
        };

        // Populate header
        document.getElementById('profile-name').textContent = profileData.firstName + ' ' + profileData.lastName;
        document.getElementById('profile-role').textContent = profileData.position;
        document.getElementById('profile-department').textContent = profileData.department;
        document.getElementById('profile-empid').textContent = profileData.employeeId;

        // Populate personal info
        document.getElementById('edit-firstName').value = profileData.firstName;
        document.getElementById('edit-lastName').value = profileData.lastName;
        document.getElementById('edit-email').value = profileData.email;
        document.getElementById('edit-phone').value = profileData.phone;
        document.getElementById('edit-dob').value = profileData.dob;
        document.getElementById('edit-address').value = profileData.address;

        // Populate employment info
        document.getElementById('emp-id').value = profileData.employeeId;
        document.getElementById('emp-position').value = profileData.position;
        document.getElementById('emp-department').value = profileData.department;
        document.getElementById('emp-hiredate').value = profileData.hireDate;
        document.getElementById('emp-supervisor').value = profileData.supervisor;
        document.getElementById('emp-status').value = profileData.status;

        // Populate leaves
        document.getElementById('annual-leave').textContent = profileData.annualLeave;
        document.getElementById('sick-leave').textContent = profileData.sickLeave;
        document.getElementById('casual-leave').textContent = profileData.casualLeave;

        // Load leave history
        loadLeaveHistory();
    }, 300);
}

function loadLeaveHistory() {
    const historyHtml = `
        <div style="padding: 1rem; border-bottom: 1px solid #e5e7eb;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h6 style="margin: 0; margin-bottom: 0.25rem;">Annual Leave - 5 days</h6>
                    <small style="color: #6b7280;">Jan 15, 2026 - Jan 19, 2026</small>
                </div>
                <span style="background: #dbeafe; color: #1e40af; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600;">Approved</span>
            </div>
        </div>
        <div style="padding: 1rem; border-bottom: 1px solid #e5e7eb;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h6 style="margin: 0; margin-bottom: 0.25rem;">Sick Leave - 2 days</h6>
                    <small style="color: #6b7280;">Feb 10, 2026 - Feb 11, 2026</small>
                </div>
                <span style="background: #fef3c7; color: #92400e; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600;">Pending</span>
            </div>
        </div>
        <div style="padding: 1rem;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h6 style="margin: 0; margin-bottom: 0.25rem;">Casual Leave - 1 day</h6>
                    <small style="color: #6b7280;">Mar 5, 2026</small>
                </div>
                <span style="background: #d1fae5; color: #065f46; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600;">Approved</span>
            </div>
        </div>
    `;
    document.getElementById('leave-history').innerHTML = historyHtml;
}
</script>
