@{
    ViewData["Title"] = "My Profile";
}

<div class="container-fluid">
    <div class="page-header">
        <h1 class="page-title"><i class="fas fa-user me-2"></i>My Profile</h1>
        <p class="page-subtitle">View your personal information</p>
    </div>
    
    <div class="row">
        <div class="col-lg-4">
            <div class="card">
                <div class="card-body text-center">
                    <div class="mb-4">
                        <div class="avatar-profile mx-auto">
                            <div class="avatar-initials" id="profile-initials">--</div>
                        </div>
                        <h4 class="mt-3 mb-0" id="profile-name">Loading...</h4>
                        <p class="text-muted" id="profile-role">-</p>
                    </div>
                    
                    <div class="list-group list-group-flush text-start">
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-envelope me-2 text-primary"></i>Email</span>
                            <span class="text-muted" id="profile-email">-</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-phone me-2 text-primary"></i>Phone</span>
                            <span class="text-muted" id="profile-phone">-</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-building me-2 text-primary"></i>Department</span>
                            <span class="text-muted" id="profile-department">-</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-user-tie me-2 text-primary"></i>Supervisor</span>
                            <span class="text-muted" id="profile-supervisor">-</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-shield-alt me-2 text-primary"></i>Status</span>
                            <span class="badge bg-success">Active</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card mt-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-chart-line me-2"></i>Quick Stats</h6>
                </div>
                <div class="card-body" id="quick-stats-body">
                    <div class="text-center text-muted">
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                        <span class="ms-2">Loading stats...</span>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <ul class="nav nav-tabs card-header-tabs">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#personal">Personal Info</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#employment">Employment</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#leaves">My Leaves</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#payroll">Payroll</a>
                        </li>
                    </ul>
                </div>
                <div class="card-body">
                    <div class="tab-content">
                        <!-- Personal Info Tab -->
                        <div class="tab-pane fade show active" id="personal">
                            <form id="personalInfoForm">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Full Name</label>
                                        <input type="text" class="form-control" id="edit-fullName" disabled>
                                        <div class="form-text">Contact HR to update your name.</div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Email</label>
                                        <input type="email" class="form-control" id="edit-email" disabled>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Phone</label>
                                        <input type="tel" class="form-control" id="edit-phone" disabled>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Age</label>
                                        <input type="number" class="form-control" id="edit-age" disabled>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Address</label>
                                    <textarea class="form-control" rows="3" id="edit-address" disabled></textarea>
                                </div>
                                <div class="alert alert-info mb-0">
                                    <i class="fas fa-info-circle me-2"></i>
                                    To update your personal information, please go to <a href="/Home/Settings">Settings</a> or contact HR.
                                </div>
                            </form>
                        </div>
                        
                        <!-- Employment Tab -->
                        <div class="tab-pane fade" id="employment">
                            <div class="table-responsive">
                                <table class="table table-borderless">
                                    <tbody id="employment-details">
                                        <tr>
                                            <th width="30%">Employee ID</th>
                                            <td id="emp-id">-</td>
                                        </tr>
                                        <tr>
                                            <th>Department</th>
                                            <td id="emp-department">-</td>
                                        </tr>
                                        <tr>
                                            <th>Supervisor</th>
                                            <td id="emp-supervisor">-</td>
                                        </tr>
                                        <tr>
                                            <th>Salary</th>
                                            <td id="emp-salary">-</td>
                                        </tr>
                                        <tr>
                                            <th>Role</th>
                                            <td id="emp-role">-</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                Employment details are managed by HR department. Contact HR for any changes.
                            </div>
                        </div>
                        
                        <!-- Leaves Tab -->
                        <div class="tab-pane fade" id="leaves">
                            <div id="my-leaves-container">
                                <div class="text-center text-muted py-4">
                                    <div class="spinner-border spinner-border-sm" role="status"></div>
                                    <span class="ms-2">Loading leaves...</span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Payroll Tab -->
                        <div class="tab-pane fade" id="payroll">
                            <div id="my-payroll-container">
                                <div class="text-center text-muted py-4">
                                    <div class="spinner-border spinner-border-sm" role="status"></div>
                                    <span class="ms-2">Loading payroll...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>