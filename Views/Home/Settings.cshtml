@{
    ViewData["Title"] = "Settings";
}

<div class="container-fluid">
    <div class="page-header">
        <h1 class="page-title"><i class="fas fa-cog me-2"></i>Settings</h1>
        <p class="page-subtitle">Manage your account preferences and security settings</p>
    </div>
    
    <div class="row">
        <div class="col-lg-3">
            <div class="card">
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <a href="#profile" class="list-group-item list-group-item-action active" data-bs-toggle="tab">
                            <i class="fas fa-user me-2"></i>Profile Settings
                        </a>
                        <a href="#security" class="list-group-item list-group-item-action" data-bs-toggle="tab">
                            <i class="fas fa-shield-alt me-2"></i>Security
                        </a>
                        <a href="#notifications" class="list-group-item list-group-item-action" data-bs-toggle="tab">
                            <i class="fas fa-bell me-2"></i>Notifications
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-9">
            <div class="tab-content">
                <!-- Profile Settings Tab -->
                <div class="tab-pane fade show active" id="profile">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-user me-2"></i>Profile Information</h5>
                        </div>
                        <div class="card-body">
                            <form id="profileForm">
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label for="profileFullName" class="form-label">Full Name</label>
                                        <input type="text" class="form-control" id="profileFullName" disabled>
                                        <div class="form-text">Contact HR to update your name.</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="profileEmail" class="form-label">Email Address</label>
                                        <input type="email" class="form-control" id="profileEmail" readonly>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label for="profilePhone" class="form-label">Phone Number</label>
                                        <input type="tel" class="form-control" id="profilePhone">
                                    </div>
                                    <div class="col-md-6">
                                        <label for="profileRole" class="form-label">Role</label>
                                        <input type="text" class="form-control" id="profileRole" readonly>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label for="profileDepartment" class="form-label">Department</label>
                                        <input type="text" class="form-control" id="profileDepartment" readonly>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="profileDesignation" class="form-label">Designation</label>
                                        <input type="text" class="form-control" id="profileDesignation" readonly>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label for="profileAddress" class="form-label">Address</label>
                                    <textarea class="form-control" id="profileAddress" rows="3"></textarea>
                                </div>
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle me-2"></i>Most profile fields are managed by HR. Contact your HR department for changes to name, department, or designation.
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                
                <!-- Security Tab -->
                <div class="tab-pane fade" id="security">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-shield-alt me-2"></i>Change Password</h5>
                        </div>
                        <div class="card-body">
                            <form id="passwordForm">
                                <div class="mb-3">
                                    <label for="currentPassword" class="form-label">Current Password</label>
                                    <input type="password" class="form-control" id="currentPassword" required>
                                </div>
                                <div class="mb-3">
                                    <label for="newPassword" class="form-label">New Password</label>
                                    <input type="password" class="form-control" id="newPassword" required>
                                    <div class="form-text">Minimum 8 characters with at least one number and one special character</div>
                                </div>
                                <div class="mb-3">
                                    <label for="confirmNewPassword" class="form-label">Confirm New Password</label>
                                    <input type="password" class="form-control" id="confirmNewPassword" required>
                                </div>
                                <button type="submit" class="btn btn-primary" id="changePasswordBtn">
                                    <i class="fas fa-key me-2"></i>Change Password
                                </button>
                            </form>
                            
                            <hr class="my-4">
                            
                            <h6 class="mb-3"><i class="fas fa-info-circle me-2"></i>Security Information</h6>
                            <div class="alert alert-info">
                                <ul class="mb-0">
                                    <li>Password must be at least 8 characters long</li>
                                    <li>Include at least one uppercase letter, one number, and one special character</li>
                                    <li>Avoid using the same password as your email or other accounts</li>
                                    <li>Change your password regularly for better security</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Notifications Tab -->
                <div class="tab-pane fade" id="notifications">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-bell me-2"></i>Recent Notifications</h5>
                        </div>
                        <div class="card-body">
                            <div id="notifications-list">
                                <div class="text-center text-muted py-4">
                                    <div class="spinner-border spinner-border-sm" role="status"></div>
                                    <span class="ms-2">Loading notifications...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            loadProfileSettings();
            loadNotifications();
        });

        function loadProfileSettings() {
            // Get employee data from the backend API
            fetch('/api/employee').then(r => {
                if (!r.ok) throw new Error('Failed');
                return r.json();
            }).then(data => {
                if (data && data.length > 0) {
                    var emp = data[0];
                    document.getElementById('profileFullName').value = (emp.firstName || '') + ' ' + (emp.middleName || '') + ' ' + (emp.lastName || '');
                    document.getElementById('profileEmail').value = emp.email || '';
                    document.getElementById('profilePhone').value = emp.phoneNumber || emp.phone || '';
                    document.getElementById('profileDepartment').value = emp.departmentName || '-';
                    document.getElementById('profileDesignation').value = emp.designation || '-';
                    document.getElementById('profileAddress').value = emp.permanentAddress || emp.address || '';
                    // Role from user claims
                    document.getElementById('profileRole').value = '@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value' || '-';
                }
            }).catch(err => {
                console.error('Failed to load profile settings:', err);
            });
        }

        // Password form submission
        document.getElementById('passwordForm').addEventListener('submit', function(e) {
            e.preventDefault();
            var currentPassword = document.getElementById('currentPassword').value;
            var newPassword = document.getElementById('newPassword').value;
            var confirmPassword = document.getElementById('confirmNewPassword').value;

            if (newPassword !== confirmPassword) {
                alert('New passwords do not match');
                return;
            }

            if (newPassword.length < 8) {
                alert('Password must be at least 8 characters');
                return;
            }

            var btn = document.getElementById('changePasswordBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Changing...';

            // Use Identity change password endpoint
            fetch('/api/users/change-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    currentPassword: currentPassword,
                    newPassword: newPassword
                })
            }).then(r => {
                if (r.ok) {
                    alert('Password changed successfully!');
                    document.getElementById('currentPassword').value = '';
                    document.getElementById('newPassword').value = '';
                    document.getElementById('confirmNewPassword').value = '';
                } else {
                    r.text().then(t => alert('Failed to change password: ' + t));
                }
            }).catch(() => {
                alert('Failed to change password. Please check your current password.');
            }).finally(() => {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-key me-2"></i>Change Password';
            });
        });

        // Load notifications using actual API endpoint
        function loadNotifications() {
            var container = document.getElementById('notifications-list');
            // Backend: GET /api/notifications
            fetch('/api/notifications').then(r => {
                if (!r.ok) throw new Error('Failed');
                return r.json();
            }).then(notifications => {
                if (!Array.isArray(notifications) || notifications.length === 0) {
                    container.innerHTML = '<div class="text-center text-muted py-4"><i class="fas fa-bell-slash fa-2x mb-2"></i><p>No notifications found.</p></div>';
                    return;
                }

                var html = '<div class="list-group">';
                notifications.slice(0, 20).forEach(function(n) {
                    var isUnread = !n.isRead;
                    var bgClass = isUnread ? 'bg-light' : '';
                    var boldClass = isUnread ? 'fw-bold' : '';
                    html += '<div class="list-group-item list-group-item-action ' + bgClass + '">' +
                        '<div class="d-flex w-100 justify-content-between">' +
                        '<h6 class="mb-1 ' + boldClass + '">' + (n.title || 'Notification') + '</h6>' +
                        '<small class="text-muted">' + formatDate(n.createdAt) + '</small>' +
                        '</div>' +
                        '<p class="mb-1 text-muted">' + (n.message || '') + '</p>' +
                        (isUnread ? '<button class="btn btn-sm btn-outline-primary mt-1" onclick="markAsRead(' + n.id + ', this)">Mark as Read</button>' : '') +
                        '</div>';
                });
                html += '</div>';
                container.innerHTML = html;
            }).catch(function() {
                container.innerHTML = '<p class="text-danger text-center">Failed to load notifications.</p>';
            });
        }

        function markAsRead(notificationId, btn) {
            // Backend: POST /api/notifications/{id}/read
            fetch('/api/notifications/' + notificationId + '/read', { method: 'POST' })
            .then(function(r) {
                if (r.ok) {
                    var item = btn.closest('.list-group-item');
                    item.classList.remove('bg-light');
                    var bold = item.querySelector('.fw-bold');
                    if (bold) bold.classList.remove('fw-bold');
                    btn.remove();
                }
            }).catch(function() {
                alert('Failed to mark notification as read.');
            });
        }

        function formatDate(dateStr) {
            if (!dateStr) return '';
            var d = new Date(dateStr);
            return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' });
        }

        // Tab switching - update active state
        document.querySelectorAll('.list-group-item-action').forEach(function(item) {
            item.addEventListener('click', function() {
                document.querySelectorAll('.list-group-item-action').forEach(function(i) { i.classList.remove('active'); });
                this.classList.add('active');
            });
        });
    </script>
}
