@{
    ViewData["Title"] = "Notifications";
    var isAdmin = User.IsInRole("Admin");
    var isHR = User.IsInRole("HRManager");
}

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;">
    <div>
        <h1 class="page-title">Notifications</h1>
        <p class="page-subtitle">Stay updated with important alerts</p>
    </div>
    <button class="btn-secondary" onclick="markAllRead()"><i class="fas fa-check-double"></i> Mark All Read</button>
</div>

<!-- Priority Filter -->
<div class="tabs">
    <button class="tab-btn active" onclick="filterNotifs(this,'all')">All</button>
    <button class="tab-btn" onclick="filterNotifs(this,'critical')">Critical</button>
    <button class="tab-btn" onclick="filterNotifs(this,'high')">High</button>
    <button class="tab-btn" onclick="filterNotifs(this,'normal')">Normal</button>
    <button class="tab-btn" onclick="filterNotifs(this,'low')">Low</button>
</div>

<!-- Notification List -->
<div class="card">
    <div class="card-body" style="padding:0;">
        <div id="notifList">
            <div class="empty-state"><i class="fas fa-bell"></i><h4>Loading notifications...</h4></div>
        </div>
    </div>
</div>


@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', loadNotifications);

function loadNotifications() {
    fetch('/api/notifications').then(r=>r.json()).then(data => {
        renderNotifications(data);
    }).catch(()=>{
        document.getElementById('notifList').innerHTML='<div class="empty-state"><i class="fas fa-bell-slash"></i><h4>No notifications</h4><p>You\'re all caught up!</p></div>';
    });
}

function renderNotifications(data) {
    var list=document.getElementById('notifList');
    if(!data||data.length===0){list.innerHTML='<div class="empty-state"><i class="fas fa-bell-slash"></i><h4>No notifications</h4><p>You\'re all caught up!</p></div>';return;}
    var priorities=['Low','Normal','High','Critical'];
    var priorityColors=['#64748b','#3b82f6','#f59e0b','#ef4444'];
    var typeIcons={Info:'fa-info-circle',Success:'fa-check-circle',Warning:'fa-exclamation-triangle',Error:'fa-times-circle',Approval:'fa-gavel',Reminder:'fa-clock',Alert:'fa-bell',System:'fa-cog'};
    list.innerHTML=data.map(n=>{
        var priority=priorities[n.priority]||'Normal';
        var color=priorityColors[n.priority]||'#3b82f6';
        var icon=typeIcons[n.type]||'fa-bell';
        return `<div class="notification-item ${n.isRead?'':'unread'}" data-priority="${priority.toLowerCase()}" onclick="markRead(${n.id})">
            <div class="notification-icon" style="background:${color}20;color:${color};"><i class="fas ${icon}"></i></div>
            <div class="notification-content">
                <div class="notification-title">${n.title||'Notification'}</div>
                <div class="notification-text">${n.message||''}</div>
                <div class="notification-time"><span class="badge-status" style="background:${color}20;color:${color};margin-right:0.5rem;">${priority}</span>${n.createdAt?timeAgo(n.createdAt):''}</div>
            </div>
            ${n.actionRequired?`<a href="${n.actionUrl||'#'}" class="btn-primary btn-sm">${n.actionButtonText||'Action'}</a>`:''}
        </div>`;
    }).join('');
}

function filterNotifs(btn, priority) {
    btn.parentElement.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.notification-item').forEach(n=>{
        n.style.display=(priority==='all'||n.dataset.priority===priority)?'':'none';
    });
}

function markRead(id) {
    fetch(`/api/notifications/${id}/read`,{method:'POST'}).catch(()=>{});
}

function markAllRead() {
    fetch('/api/notifications/mark-all-read',{method:'POST'}).then(()=>{
        document.querySelectorAll('.notification-item.unread').forEach(n=>n.classList.remove('unread'));
    }).catch(()=>{});
}

function timeAgo(date) {
    var d=new Date(date);
    var now=new Date();
    var diff=Math.floor((now-d)/1000);
    if(diff<60) return 'Just now';
    if(diff<3600) return Math.floor(diff/60)+'m ago';
    if(diff<86400) return Math.floor(diff/3600)+'h ago';
    return Math.floor(diff/86400)+'d ago';
}
</script>
}