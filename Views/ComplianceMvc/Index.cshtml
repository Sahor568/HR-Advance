@{
    ViewData["Title"] = "Compliance Management";
    Layout = "_Layout";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="page-title-box">
                <h4 class="page-title">Compliance Management</h4>
                <p class="text-muted">Ensure regulatory compliance and workplace safety</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="avatar-sm rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center">
                                <i class="fas fa-file-contract fa-2x"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="card-title mb-1">Audit Reports</h5>
                            <p class="text-muted mb-0">Labor law compliance audits</p>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="@Url.Action("AuditReports", "ComplianceMvc")" class="btn btn-primary w-100">Manage Reports</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="avatar-sm rounded-circle bg-warning bg-opacity-10 text-warning d-flex align-items-center justify-content-center">
                                <i class="fas fa-exclamation-triangle fa-2x"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="card-title mb-1">Accident Logs</h5>
                            <p class="text-muted mb-0">Workplace accident tracking</p>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="@Url.Action("Accidents", "ComplianceMvc")" class="btn btn-warning w-100">View Accidents</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="avatar-sm rounded-circle bg-success bg-opacity-10 text-success d-flex align-items-center justify-content-center">
                                <i class="fas fa-heartbeat fa-2x"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="card-title mb-1">Insurance Claims</h5>
                            <p class="text-muted mb-0">Medical & insurance claims</p>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="@Url.Action("InsuranceClaims", "ComplianceMvc")" class="btn btn-success w-100">Manage Claims</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="avatar-sm rounded-circle bg-danger bg-opacity-10 text-danger d-flex align-items-center justify-content-center">
                                <i class="fas fa-gavel fa-2x"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="card-title mb-1">Disciplinary Cases</h5>
                            <p class="text-muted mb-0">Employee disciplinary actions</p>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="@Url.Action("DisciplinaryCases", "ComplianceMvc")" class="btn btn-danger w-100">View Cases</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Compliance Overview</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="alert alert-info">
                                <h6 class="alert-heading"><i class="fas fa-shield-alt me-2"></i>Compliance Status</h6>
                                <p class="mb-0">Ensure your organization meets all labor law requirements, workplace safety standards, and regulatory obligations.</p>
                            </div>
                            <div class="d-grid gap-2">
                                <a href="@Url.Action("Dashboard", "ComplianceMvc")" class="btn btn-outline-primary">
                                    <i class="fas fa-tachometer-alt me-2"></i>Compliance Dashboard
                                </a>
                                <a href="@Url.Action("Stats", "ComplianceMvc")" class="btn btn-outline-secondary">
                                    <i class="fas fa-chart-bar me-2"></i>View Statistics
                                </a>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="alert alert-light">
                                <h6 class="alert-heading"><i class="fas fa-calendar-check me-2"></i>Upcoming Requirements</h6>
                                <ul class="mb-0 ps-3">
                                    <li>Monthly accident report due in 5 days</li>
                                    <li>Quarterly labor audit due in 15 days</li>
                                    <li>Annual compliance review in 2 months</li>
                                    <li>Insurance claim processing - ongoing</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="@Url.Action("CreateAuditReport", "ComplianceMvc")" class="btn btn-primary">
                            <i class="fas fa-plus-circle me-2"></i>New Audit Report
                        </a>
                        <a href="@Url.Action("CreateAccidentLog", "ComplianceMvc")" class="btn btn-warning">
                            <i class="fas fa-exclamation-circle me-2"></i>Log Accident
                        </a>
                        <a href="@Url.Action("CreateInsuranceClaim", "ComplianceMvc")" class="btn btn-success">
                            <i class="fas fa-file-medical me-2"></i>Submit Insurance Claim
                        </a>
                        <a href="@Url.Action("CreateDisciplinaryCase", "ComplianceMvc")" class="btn btn-danger">
                            <i class="fas fa-user-times me-2"></i>Create Disciplinary Case
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Recent Compliance Activities</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Description</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>2026-05-01</td>
                                    <td><span class="badge bg-primary">Audit Report</span></td>
                                    <td>Q1 Labor Law Compliance Audit</td>
                                    <td><span class="badge bg-success">Completed</span></td>
                                    <td><a href="#" class="btn btn-sm btn-outline-primary">View</a></td>
                                </tr>
                                <tr>
                                    <td>2026-04-28</td>
                                    <td><span class="badge bg-warning">Accident</span></td>
                                    <td>Minor workplace injury - First aid applied</td>
                                    <td><span class="badge bg-success">Resolved</span></td>
                                    <td><a href="#" class="btn btn-sm btn-outline-warning">View</a></td>
                                </tr>
                                <tr>
                                    <td>2026-04-25</td>
                                    <td><span class="badge bg-success">Insurance Claim</span></td>
                                    <td>Medical reimbursement - Employee #1024</td>
                                    <td><span class="badge bg-info">Pending</span></td>
                                    <td><a href="#" class="btn btn-sm btn-outline-success">Review</a></td>
                                </tr>
                                <tr>
                                    <td>2026-04-20</td>
                                    <td><span class="badge bg-danger">Disciplinary</span></td>
                                    <td>Code of conduct violation - Written warning</td>
                                    <td><span class="badge bg-success">Closed</span></td>
                                    <td><a href="#" class="btn btn-sm btn-outline-danger">View</a></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize any compliance-specific scripts
            console.log('Compliance management page loaded');
        });
    </script>
}