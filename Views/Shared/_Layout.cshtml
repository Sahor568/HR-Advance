@{
    var isLoginPage = ViewData["HideLayout"] != null && (bool)ViewData["HideLayout"];
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var userRole = "Guest";
    var userName = "Guest";
    var userInitials = "G";
    if (User.Identity?.IsAuthenticated == true)
    {
        userName = User.Identity.Name ?? "User";
        userInitials = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";
        if (User.IsInRole("Admin")) userRole = "Admin";
        else if (User.IsInRole("HRManager")) userRole = "HR Manager";
        else if (User.IsInRole("Employee")) userRole = "Employee";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HRMS Nepal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
@if (isLoginPage)
{
    @RenderBody()
}
else
{
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon"><i class="fas fa-building"></i></div>
            <span class="sidebar-brand-text">HRMS Nepal</span>
        </div>
        <nav class="sidebar-nav">
            <div class="sidebar-nav-section">Main</div>
            <a href="/Home/Dashboard" class="sidebar-nav-item @(currentAction == "Dashboard" ? "active" : "")">
                <i class="fas fa-th-large"></i> Dashboard
            </a>

            @if (User.IsInRole("Admin") || User.IsInRole("HRManager"))
            {
                <div class="sidebar-nav-section">Management</div>
                <a href="/Users" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Users") ? "active" : "")">
                    <i class="fas fa-user-plus"></i> Users
                </a>
                <a href="/Employees" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Employees") ? "active" : "")">
                    <i class="fas fa-users"></i> Employees
                </a>
                <a href="/Departments" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Departments") ? "active" : "")">
                    <i class="fas fa-sitemap"></i> Departments
                </a>
                <a href="/Team" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Team") ? "active" : "")">
                    <i class="fas fa-user-friends"></i> Teams
                </a>
                <a href="/Performance" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Performance") ? "active" : "")">
                    <i class="fas fa-chart-line"></i> Performance
                </a>
                <a href="/Recruitment" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Recruitment") ? "active" : "")">
                    <i class="fas fa-briefcase"></i> Recruitment
                </a>
                <a href="/Expenses" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Expenses") ? "active" : "")">
                    <i class="fas fa-receipt"></i> Expenses
                </a>
                <a href="/SSF" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/SSF") ? "active" : "")">
                    <i class="fas fa-shield-alt"></i> SSF
                </a>
                <a href="/Compliance" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Compliance") ? "active" : "")">
                    <i class="fas fa-gavel"></i> Compliance
                </a>
            }

            <div class="sidebar-nav-section">Operations</div>
            <a href="/Attendances" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Attendances") ? "active" : "")">
                <i class="fas fa-clock"></i> Attendance
            </a>
            <a href="/Leaves" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Leaves") ? "active" : "")">
                <i class="fas fa-calendar-minus"></i> Leave
            </a>
            <a href="/Payrolls" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Payrolls") ? "active" : "")">
                <i class="fas fa-money-bill-wave"></i> Payroll
            </a>
            <a href="/Holidays" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Holidays") ? "active" : "")">
                <i class="fas fa-umbrella-beach"></i> Holidays
            </a>
            <a href="/Team/MyTeams" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Team/MyTeams") ? "active" : "")">
                <i class="fas fa-user-friends"></i> My Teams
            </a>
            <a href="/Team/MyTasks" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Team/MyTasks") ? "active" : "")">
                <i class="fas fa-tasks"></i> My Tasks
            </a>

            @if (User.IsInRole("Admin") || User.IsInRole("HRManager"))
            {
                <div class="sidebar-nav-section">Reports</div>
                <a href="/MasterSheet" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/MasterSheet") ? "active" : "")">
                    <i class="fas fa-table"></i> Master Sheet
                </a>
                <a href="/EmployeeHistory" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/EmployeeHistory") ? "active" : "")">
                    <i class="fas fa-history"></i> Employee History
                </a>
            }
            
            @if (User.IsInRole("Admin"))
            {
                <a href="/Logs" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Logs") ? "active" : "")">
                    <i class="fas fa-file-alt"></i> Logs
                </a>
            }

            <div class="sidebar-nav-section">Account</div>
            <a href="/Notifications" class="sidebar-nav-item @(Context.Request.Path.StartsWithSegments("/Notifications") ? "active" : "")">
                <i class="fas fa-bell"></i> Notifications
            </a>
            <a href="/Home/Profile" class="sidebar-nav-item @(currentAction == "Profile" ? "active" : "")">
                <i class="fas fa-user-circle"></i> Profile
            </a>
        </nav>
        <div class="sidebar-user">
            <div class="sidebar-user-avatar">@userInitials</div>
            <div class="sidebar-user-info">
                <div class="sidebar-user-name">@userName</div>
                <div class="sidebar-user-role">@userRole</div>
            </div>
        </div>
    </aside>

    <!-- Header -->
    <header class="main-header">
        <div class="header-left">
            <button class="header-btn d-md-none" onclick="document.getElementById('sidebar').classList.toggle('open')">
                <i class="fas fa-bars"></i>
            </button>
            <div class="header-search">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search..." id="globalSearch" />
            </div>
        </div>
        <div class="header-right">
            <a href="/Notifications" class="header-btn" title="Notifications">
                <i class="fas fa-bell"></i>
                <span class="badge" id="notifBadge" style="display:none;">0</span>
            </a>
            <a href="/Home/Profile" class="header-btn" title="Profile">
                <i class="fas fa-user"></i>
            </a>
            <form action="/Account/Logout" method="post" style="margin:0;">
                @Html.AntiForgeryToken()
                <button type="submit" class="header-btn" title="Logout">
                    <i class="fas fa-sign-out-alt"></i>
                </button>
            </form>
        </div>
    </header>

    <!-- Main Content -->
    <main class="main-content">
        @RenderBody()
    </main>
}

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/responsive.bootstrap5.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>