@model IEnumerable<HR_Management_System.Models.ViewModels.TaskExtensionRequestViewModel>

@{
    ViewData["Title"] = "Extension Requests";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Teams</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Extension Requests</li>
                </ol>
            </nav>
            <h1 class="h3 mb-0">Extension Requests</h1>
            <p class="text-muted">Manage task extension requests from employees</p>
        </div>
        <div class="col-auto">
            <div class="btn-group">
                <button type="button" class="btn btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-filter me-2"></i>Filter by Status
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="?status=1">Pending</a></li>
                    <li><a class="dropdown-item" href="?status=2">Approved</a></li>
                    <li><a class="dropdown-item" href="?status=3">Rejected</a></li>
                    <li><a class="dropdown-item" href="?status=4">Cancelled</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item" href="?">All Requests</a></li>
                </ul>
            </div>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Extension Requests</h5>
                </div>
                <div class="card-body">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No extension requests found</h5>
                            <p class="text-muted">There are no extension requests to display.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Task</th>
                                        <th>Requested By</th>
                                        <th>Current Deadline</th>
                                        <th>Requested Deadline</th>
                                        <th>Reason</th>
                                        <th>Status</th>
                                        <th>Performance Deduction</th>
                                        <th>Created</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var request in Model)
                                    {
                                        <tr>
                                            <td>@request.Id</td>
                                            <td>
                                                <strong>@request.TaskTitle</strong><br />
                                                <small class="text-muted">Task ID: @request.TaskId</small>
                                            </td>
                                            <td>
                                                @request.RequestedByEmployeeName<br />
                                                <small class="text-muted">ID: @request.RequestedByEmployeeId</small>
                                            </td>
                                            <td>
                                                @* Current deadline would need to be fetched from task *@
                                                <span class="text-muted">N/A</span>
                                            </td>
                                            <td>@request.RequestedDeadline.ToString("yyyy-MM-dd")</td>
                                            <td>
                                                <div class="text-truncate" style="max-width: 200px;" 
                                                     data-bs-toggle="tooltip" data-bs-placement="top" 
                                                     title="@request.Reason">
                                                    @request.Reason
                                                </div>
                                            </td>
                                            <td>
                                                @{
                                                    var statusClass = request.Status switch
                                                    {
                                                        1 => "badge bg-warning", // Pending
                                                        2 => "badge bg-success", // Approved
                                                        3 => "badge bg-danger",  // Rejected
                                                        4 => "badge bg-secondary", // Cancelled
                                                        _ => "badge bg-secondary"
                                                    };
                                                }
                                                <span class="@statusClass">@request.StatusName</span>
                                            </td>
                                            <td>
                                                @if (request.IsDeductionApplied)
                                                {
                                                    <span class="badge bg-danger">-@request.PerformanceDeduction pts</span>
                                                }
                                                else if (request.Status == 2) // Approved but deduction not applied
                                                {
                                                    <span class="badge bg-warning">Pending</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>@request.CreatedAt.ToString("yyyy-MM-dd")</td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    @if (request.Status == 1) // Pending
                                                    {
                                                        <a asp-action="ReviewExtensionRequest" asp-route-id="@request.Id" 
                                                           class="btn btn-outline-primary" title="Review">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <a asp-action="ReviewExtensionRequest" asp-route-id="@request.Id" 
                                                           class="btn btn-outline-secondary" title="View Details">
                                                            <i class="fas fa-info-circle"></i>
                                                        </a>
                                                    }
                                                    
                                                    @if (request.Status == 1 && User.IsInRole("Admin") || User.IsInRole("HR"))
                                                    {
                                                        <button type="button" class="btn btn-outline-success" 
                                                                data-bs-toggle="modal" data-bs-target="#approveModal@(request.Id)"
                                                                title="Approve">
                                                            <i class="fas fa-check"></i>
                                                        </button>
                                                        <button type="button" class="btn btn-outline-danger" 
                                                                data-bs-toggle="modal" data-bs-target="#rejectModal@(request.Id)"
                                                                title="Reject">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    }
                                                </div>

                                                <!-- Approve Modal -->
                                                <div class="modal fade" id="approveModal@(request.Id)" tabindex="-1" aria-hidden="true">
                                                    <div class="modal-dialog">
                                                        <div class="modal-content">
                                                            <div class="modal-header">
                                                                <h5 class="modal-title">Approve Extension Request</h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                            </div>
                                                            <form asp-action="ReviewExtensionRequest" method="post">
                                                                <input type="hidden" name="id" value="@request.Id" />
                                                                <input type="hidden" name="approve" value="true" />
                                                                <div class="modal-body">
                                                                    <p>Are you sure you want to approve this extension request?</p>
                                                                    <div class="mb-3">
                                                                        <label class="form-label">Comments (Optional)</label>
                                                                        <textarea name="comments" class="form-control" rows="3" 
                                                                                  placeholder="Add any comments for the employee..."></textarea>
                                                                    </div>
                                                                    <div class="alert alert-warning">
                                                                        <i class="fas fa-exclamation-triangle me-2"></i>
                                                                        <strong>Note:</strong> Approving this request will apply a performance deduction to the employee.
                                                                    </div>
                                                                </div>
                                                                <div class="modal-footer">
                                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                                    <button type="submit" class="btn btn-success">Approve Request</button>
                                                                </div>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Reject Modal -->
                                                <div class="modal fade" id="rejectModal@(request.Id)" tabindex="-1" aria-hidden="true">
                                                    <div class="modal-dialog">
                                                        <div class="modal-content">
                                                            <div class="modal-header">
                                                                <h5 class="modal-title">Reject Extension Request</h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                            </div>
                                                            <form asp-action="ReviewExtensionRequest" method="post">
                                                                <input type="hidden" name="id" value="@request.Id" />
                                                                <input type="hidden" name="approve" value="false" />
                                                                <div class="modal-body">
                                                                    <p>Are you sure you want to reject this extension request?</p>
                                                                    <div class="mb-3">
                                                                        <label class="form-label">Comments (Optional)</label>
                                                                        <textarea name="comments" class="form-control" rows="3" 
                                                                                  placeholder="Provide reason for rejection..."></textarea>
                                                                    </div>
                                                                </div>
                                                                <div class="modal-footer">
                                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                                    <button type="submit" class="btn btn-danger">Reject Request</button>
                                                                </div>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="row mt-3">
                            <div class="col">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="text-muted">Showing @Model.Count() extension requests</span>
                                    </div>
                                    <div>
                                        <span class="badge bg-warning">@Model.Count(r => r.Status == 1) Pending</span>
                                        <span class="badge bg-success ms-2">@Model.Count(r => r.Status == 2) Approved</span>
                                        <span class="badge bg-danger ms-2">@Model.Count(r => r.Status == 3) Rejected</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });

            // Filter functionality
            $('.dropdown-item').click(function(e) {
                var status = $(this).attr('href').split('=')[1];
                if (status) {
                    window.location.href = '@Url.Action("ExtensionRequests")?status=' + status;
                } else {
                    window.location.href = '@Url.Action("ExtensionRequests")';
                }
                e.preventDefault();
            });
        });
    </script>
}