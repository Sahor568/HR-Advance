@model IEnumerable<HR_Management_System.Models.ViewModels.TeamListViewModel>

@{
    ViewData["Title"] = "My Teams";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3 mb-0">My Teams</h1>
            <p class="text-muted">Teams that you are a member of</p>
        </div>
        <div class="col-auto">
            <a asp-action="MyTasks" class="btn btn-outline-primary">
                <i class="fas fa-tasks"></i> View My Tasks
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="fas fa-users fa-4x text-muted mb-4"></i>
                <h4 class="text-muted">You are not a member of any teams yet</h4>
                <p class="text-muted">When you are added to a team, it will appear here.</p>
                <a asp-controller="Home" asp-action="Dashboard" class="btn btn-outline-primary">Go to Dashboard</a>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var team in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">@team.Name</h5>
                            @if (team.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(team.Description))
                            {
                                <p class="card-text">@team.Description</p>
                            }
                            <div class="mb-3">
                                <small class="text-muted d-block">
                                    <i class="fas fa-building"></i> @team.DepartmentName
                                </small>
                                <small class="text-muted d-block">
                                    <i class="fas fa-user"></i> Created by: @team.CreatorName
                                </small>
                                <small class="text-muted d-block">
                                    <i class="fas fa-calendar"></i> Created: @team.CreatedAt.ToString("dd MMM yyyy")
                                </small>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="badge bg-info me-2">
                                        <i class="fas fa-users"></i> @team.MemberCount
                                    </span>
                                    <span class="badge bg-secondary">
                                        <i class="fas fa-tasks"></i> @team.TaskCount
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="d-grid">
                                <a asp-action="Details" asp-route-id="@team.Id" class="btn btn-outline-primary">
                                    <i class="fas fa-eye"></i> View Team Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>