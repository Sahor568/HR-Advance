@model IEnumerable<HR_Management_System.Models.ViewModels.TeamListViewModel>

@{
    ViewData["Title"] = "Teams";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3 mb-0">Teams</h1>
            <p class="text-muted">Manage and view all teams in the organization</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Create New Team
            </a>
            <a asp-action="MyTeams" class="btn btn-outline-secondary">
                <i class="fas fa-users"></i> My Teams
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover" id="teamsTable">
                    <thead>
                        <tr>
                            <th>Team Name</th>
                            <th>Department</th>
                            <th>Created By</th>
                            <th>Members</th>
                            <th>Tasks</th>
                            <th>Created Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var team in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@team.Name</strong>
                                    @if (!string.IsNullOrEmpty(team.Description))
                                    {
                                        <br />
                                        <small class="text-muted">@team.Description</small>
                                    }
                                </td>
                                <td>@team.DepartmentName</td>
                                <td>@team.CreatorName</td>
                                <td>
                                    <span class="badge bg-info">@team.MemberCount members</span>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@team.TaskCount tasks</span>
                                </td>
                                <td>@team.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (team.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@team.Id" class="btn btn-sm btn-outline-primary" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@team.Id" class="btn btn-sm btn-outline-secondary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        @if (team.IsActive)
                                        {
                                            <form asp-action="Deactivate" asp-route-id="@team.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to deactivate this team?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-warning" title="Deactivate">
                                                    <i class="fas fa-pause"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Activate" asp-route-id="@team.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to activate this team?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-success" title="Activate">
                                                    <i class="fas fa-play"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#teamsTable').DataTable({
                pageLength: 10,
                responsive: true,
                order: [[5, 'desc']] // Sort by Created Date descending
            });
        });
    </script>
}