@{
    ViewData["Title"] = "Holidays";
    var isAdminOrHR = User.IsInRole("Admin") || User.IsInRole("HRManager");
}

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;">
    <div>
        <h1 class="page-title">Holidays</h1>
        <p class="page-subtitle">Public holidays and calendar (holidays count as working days)</p>
    </div>
    @if (isAdminOrHR)
    {
        <button class="btn-primary" onclick="openAddHoliday()"><i class="fas fa-plus"></i> Add Holiday</button>
    }
</div>

<!-- Today's Holiday Banner -->
<div id="todayHolidayBanner" style="display:none;"></div>

<!-- Holiday List -->
<div class="table-container">
    <div class="table-header">
        <h3 style="font-size:1rem;font-weight:600;margin:0;">Holiday Calendar</h3>
        <div class="filter-bar">
            <input type="number" class="form-control" id="holidayYear" value="2026" style="width:100px;" onchange="loadHolidays()" />
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Holiday Name</th>
                <th>Date</th>
                <th>Nepali Date</th>
                <th>Day</th>
                <th>Women Only</th>
                <th>Status</th>
                @if (isAdminOrHR) { <th>Actions</th> }
            </tr>
        </thead>
        <tbody id="holidayBody">
            <tr><td colspan="7" class="text-center" style="padding:2rem;">Loading...</td></tr>
        </tbody>
    </table>
</div>

<!-- Add/Edit Holiday Modal -->
@if (isAdminOrHR)
{
    <div class="modal-overlay" id="holidayModal">
        <div class="modal-box">
            <div class="modal-header">
                <h3 id="holidayModalTitle">Add Holiday</h3>
                <button class="modal-close" onclick="closeModal('holidayModal')">X</button>
            </div>
            <div class="modal-body">
                <form id="holidayForm">
                    <input type="hidden" id="holidayId" />
                    <div class="form-group"><label class="form-label">Holiday Name *</label><input type="text" class="form-control" id="holidayName" required /></div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                        <div class="form-group"><label class="form-label">Date *</label><input type="date" class="form-control" id="holidayDate" required /></div>
                        <div class="form-group"><label class="form-label">Nepali Date</label><input type="text" class="form-control" id="holidayNepaliDate" placeholder="e.g. 2081-01-01" /></div>
                    </div>
                    <div class="form-group"><label class="form-label">Description</label><textarea class="form-control" id="holidayDesc" rows="2"></textarea></div>
                    <div class="form-group">
                        <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.85rem;cursor:pointer;">
                            <input type="checkbox" id="holidayWomenOnly" /> Women Only Holiday
                        </label>
                    </div>
                    <div style="background:#ecfdf5;border:1px solid #a7f3d0;border-radius:var(--radius);padding:0.75rem;">
                        <p style="font-size:0.8rem;color:#065f46;margin:0;"><i class="fas fa-info-circle"></i> Holidays are counted as working days for payroll and attendance purposes.</p>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeModal('holidayModal')">Cancel</button>
                <button class="btn-primary" onclick="saveHoliday()"><i class="fas fa-save"></i> Save</button>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
var isAdminOrHR = @(isAdminOrHR ? "true" : "false");
document.addEventListener('DOMContentLoaded', function() { loadHolidays(); checkTodayHoliday(); });

function loadHolidays() {
    var year = document.getElementById('holidayYear').value;
    fetch('/api/leave/holidays?year=' + year).then(r=>r.json()).then(data => {
        renderHolidays(data);
    }).catch(()=>{ document.getElementById('holidayBody').innerHTML='<tr><td colspan="7" class="text-center">Failed to load</td></tr>'; });
}

function renderHolidays(data) {
    var tbody = document.getElementById('holidayBody');
    if(!data||data.length===0){tbody.innerHTML='<tr><td colspan="7"><div class="empty-state"><i class="fas fa-umbrella-beach"></i><h4>No holidays</h4></div></td></tr>';return;}
    var today = new Date().toISOString().split('T')[0];
    tbody.innerHTML=data.map(h=>{
        var d=h.holidayDate?new Date(h.holidayDate):null;
        var isToday=h.holidayDate&&h.holidayDate.split('T')[0]===today;
        var isPast=d&&d<new Date()&&!isToday;
        return `<tr style="${isToday?'background:#fef3c7;':''}">
            <td style="font-weight:${isToday?'600':'400'};">${h.holidayName||'-'}</td>
            <td>${d?d.toLocaleDateString():'-'}</td>
            <td>${h.nepaliDate||'-'}</td>
            <td>${d?d.toLocaleDateString('en-US',{weekday:'long'}):'-'}</td>
            <td>${h.isForWomenOnly?'<span class="badge-status badge-info">Yes</span>':'-'}</td>
            <td><span class="badge-status ${isToday?'badge-warning':isPast?'badge-secondary':'badge-success'}">${isToday?'Today':isPast?'Past':'Upcoming'}</span></td>
            ${isAdminOrHR?`<td><div class="d-flex gap-1"><button class="btn-icon" title="Edit" onclick="editHoliday(${h.id})"><i class="fas fa-edit"></i></button><button class="btn-icon" title="Delete" onclick="deleteHoliday(${h.id})"><i class="fas fa-trash"></i></button></div></td>`:'<td></td>'}
        </tr>`;
    }).join('');
}

function checkTodayHoliday() {
    var currentYear = new Date().getFullYear();
    fetch('/api/leave/holidays?year=' + currentYear).then(r=>r.json()).then(holidays=>{
        var today=new Date().toISOString().split('T')[0];
        var h=holidays.find(x=>x.holidayDate&&x.holidayDate.split('T')[0]===today);
        if(h){
            document.getElementById('todayHolidayBanner').style.display='block';
            document.getElementById('todayHolidayBanner').innerHTML='<div class="holiday-today"><i class="fas fa-umbrella-beach"></i><h3>Today is a Holiday!</h3><p>'+h.holidayName+'</p></div>';
        }
    }).catch(()=>{});
}

function openAddHoliday() {
    document.getElementById('holidayModalTitle').textContent='Add Holiday';
    document.getElementById('holidayForm').reset();
    document.getElementById('holidayId').value='';
    document.getElementById('holidayModal').classList.add('active');
}

function editHoliday(id) {
    var year = document.getElementById('holidayYear').value;
    fetch('/api/leave/holidays?year=' + year).then(r=>r.json()).then(holidays=>{
        var h=holidays.find(x=>x.id===id);
        if(h){
            document.getElementById('holidayModalTitle').textContent='Edit Holiday';
            document.getElementById('holidayId').value=h.id;
            document.getElementById('holidayName').value=h.holidayName||'';
            document.getElementById('holidayDate').value=h.holidayDate?h.holidayDate.split('T')[0]:'';
            document.getElementById('holidayNepaliDate').value=h.nepaliDate||'';
            document.getElementById('holidayDesc').value=h.description||'';
            document.getElementById('holidayWomenOnly').checked=h.isForWomenOnly||false;
            document.getElementById('holidayModal').classList.add('active');
        }
    }).catch(()=>alert('Failed'));
}

function saveHoliday() {
    var id=document.getElementById('holidayId').value;
    var holidayDate = document.getElementById('holidayDate').value;
    
    // Create the holiday object
    var body={
        holidayName: document.getElementById('holidayName').value,
        holidayDate: holidayDate,
        nepaliDate: document.getElementById('holidayNepaliDate').value,
        description: document.getElementById('holidayDesc').value,
        isForWomenOnly: document.getElementById('holidayWomenOnly').checked,
        isActive: true
    };
    
    // Only include id for updates
    if (id) {
        body.id = parseInt(id);
    }
    
    var url=id ? `/api/leave/holidays/${id}` : '/api/leave/holidays';
    var method=id ? 'PUT' : 'POST';
    fetch(url,{method,headers:{'Content-Type':'application/json'},body:JSON.stringify(body)}).then(r=>{
        if(r.ok){closeModal('holidayModal');loadHolidays();alert('Holiday saved!');}
        else r.text().then(t=>alert('Error: '+t));
    }).catch(()=>alert('Failed'));
}

function deleteHoliday(id) {
    if(!confirm('Delete this holiday?'))return;
    fetch(`/api/leave/holidays/${id}`,{method:'DELETE'}).then(r=>{
        if(r.ok || r.status === 204) {
            loadHolidays();
            alert('Holiday deleted!');
        } else {
            alert('Failed to delete holiday');
        }
    }).catch(()=>alert('Error'));
}

function closeModal(id){document.getElementById(id).classList.remove('active');}
</script>
}