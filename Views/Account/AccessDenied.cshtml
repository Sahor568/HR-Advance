@{
    ViewData["Title"] = "Access Denied";
}

<div class="page-header">
    <h1 class="page-title">
        <i class="fas fa-ban" style="color: #ef4444;"></i>
        Access Denied
    </h1>
    <p class="page-subtitle">You don't have permission to access this resource</p>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-body text-center" style="padding: 3rem 2rem;">
        <div style="font-size: 5rem; color: #ef4444; margin-bottom: 1.5rem;">
            <i class="fas fa-lock"></i>
        </div>
        <h2 style="margin-bottom: 1rem;">Unauthorized Access</h2>
        <p style="color: #6b7280; margin-bottom: 2rem;">
            The page or resource you're trying to access requires permissions that your account doesn't have.
        </p>
        <p style="color: #6b7280; margin-bottom: 2rem;">
            If you believe this is a mistake, please contact your administrator.
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
            <a href="@Url.Action("Dashboard", "Home")" class="btn btn-primary">
                <i class="fas fa-home"></i> Go to Dashboard
            </a>
            <a href="@Url.Action("Logout", "Account")" class="btn btn-secondary">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </div>
    </div>
</div>
