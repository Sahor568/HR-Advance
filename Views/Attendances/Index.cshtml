@{
    ViewData["Title"] = "Attendance Management";
}

<div class="page-header">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h1 class="page-title">Attendance Management</h1>
            <p class="page-subtitle">Track and manage employee attendance</p>
        </div>
        <button class="btn btn-primary" onclick="openMarkAttendanceModal()" id="mark-attendance-btn" style="display:none;">
            <i class="fas fa-plus"></i> Mark Attendance
        </button>
    </div>
</div>

<!-- Check-In/Check-Out Area -->
<div class="check-in-area" id="checkInArea" style="display: none;">
    <div class="check-in-time" id="greeting">Good Morning! Time to Check In</div>
    <div class="time-display" id="currentTime">00:00:00</div>
    <div class="check-btn-group">
        <button class="btn" style="background: rgba(255,255,255,0.2); border: 2px solid white; color: white;" onclick="checkIn()" id="checkInBtn">
            <i class="fas fa-sign-in-alt"></i> Check In
        </button>
        <button class="btn" style="background: rgba(255,255,255,0.2); border: 2px solid white; color: white;" onclick="checkOut()" id="checkOutBtn">
            <i class="fas fa-sign-out-alt"></i> Check Out
        </button>
    </div>
    <div class="check-status" id="checkStatus"></div>
</div>

<!-- Attendance Statistics -->
<div class="attendance-stats">
    <div class="stat-card">
        <i class="fas fa-check-circle" style="color: var(--success-color); font-size: 1.5rem;"></i>
        <div class="stat-number" style="color: var(--success-color);" id="stat-present">--</div>
        <div class="stat-label">Present Today</div>
    </div>
    <div class="stat-card">
        <i class="fas fa-times-circle" style="color: var(--danger-color); font-size: 1.5rem;"></i>
        <div class="stat-number" style="color: var(--danger-color);" id="stat-absent">--</div>
        <div class="stat-label">Absent Today</div>
    </div>
    <div class="stat-card">
        <i class="fas fa-clock" style="color: var(--warning-color); font-size: 1.5rem;"></i>
        <div class="stat-number" style="color: var(--warning-color);" id="stat-late">--</div>
        <div class="stat-label">Late Today</div>
    </div>
    <div class="stat-card">
        <i class="fas fa-percentage" style="color: var(--primary-color); font-size: 1.5rem;"></i>
        <div class="stat-number" style="color: var(--primary-color);" id="stat-rate">--</div>
        <div class="stat-label">Attendance Rate</div>
    </div>
</div>

<!-- Filters -->
<div style="display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
    <input type="date" class="form-control" id="filterDate" style="max-width: 150px;">
    <select class="form-control" id="filterStatus" style="max-width: 150px;" onchange="loadAttendance()">
        <option value="">All Status</option>
        <option value="Present">Present</option>
        <option value="Absent">Absent</option>
        <option value="Late">Late</option>
    </select>
</div>

<!-- Attendance Records -->
<div class="card">
    <div class="card-header">
        <h5 style="margin: 0;">
            <i class="fas fa-list"></i> Attendance Records
        </h5>
    </div>
    <div class="card-body" style="padding: 0;">
        <div style="max-height: 600px; overflow-y: auto;" id="attendance-records">
            <div style="text-align:center;padding:3rem;color:var(--text-light);">
                <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
                <p style="margin-top:1rem;">Loading attendance records...</p>
            </div>
        </div>
    </div>
</div>

<!-- Mark Attendance Modal (Admin/HR) -->
<div class="modal-overlay" id="attendanceModal">
    <div class="modal-box">
        <div class="modal-header">
            <h5 style="margin:0;">Mark Attendance</h5>
            <button onclick="closeAttendanceModal()" style="background:none;border:none;font-size:1.5rem;cursor:pointer;">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group" style="margin-bottom:1rem;">
                <label>Employee <span style="color:red;">*</span></label>
                <select class="form-control" id="attEmployeeId">
                    <option value="">Select Employee</option>
                </select>
            </div>
            <div class="form-group" style="margin-bottom:1rem;">
                <label>Date <span style="color:red;">*</span></label>
                <input type="date" class="form-control" id="attDate">
            </div>
            <div class="form-group" style="margin-bottom:1rem;">
                <label>Status <span style="color:red;">*</span></label>
                <select class="form-control" id="attStatus">
                    <option value="Present">Present</option>
                    <option value="Absent">Absent</option>
                    <option value="Late">Late</option>
                </select>
            </div>
            <div class="form-group" style="margin-bottom:1rem;">
                <label>Check In Time</label>
                <input type="time" class="form-control" id="attCheckIn">
            </div>
            <div class="form-group" style="margin-bottom:1rem;">
                <label>Check Out Time</label>
                <input type="time" class="form-control" id="attCheckOut">
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline-secondary" onclick="closeAttendanceModal()">Cancel</button>
            <button class="btn btn-primary" onclick="markAttendance()">Save</button>
        </div>
    </div>
</div>
