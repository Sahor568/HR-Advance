@{
    ViewData["Title"] = "Attendance";
    var isAdminOrHR = User.IsInRole("Admin") || User.IsInRole("HRManager");
}

<style>
    .holiday-row { background-color: #e8f5e9 !important; }
    .weekend-row { background-color: #f5f5f5 !important; }
    .pending-row { background-color: #fff3e0 !important; }
    .badge-holiday { background: #4caf50; color: white; padding: 3px 8px; border-radius: 12px; font-size: 0.75rem; }
    .badge-weekend { background: #9e9e9e; color: white; padding: 3px 8px; border-radius: 12px; font-size: 0.75rem; }
    .badge-pending { background: #ff9800; color: white; padding: 3px 8px; border-radius: 12px; font-size: 0.75rem; }
    .approve-btn { background: #4caf50; color: white; border: none; padding: 4px 12px; border-radius: 4px; cursor: pointer; }
    .reject-btn { background: #f44336; color: white; border: none; padding: 4px 12px; border-radius: 4px; cursor: pointer; }
    .approve-btn:hover { background: #388e3c; }
    .reject-btn:hover { background: #d32f2f; }
    .nepali-date { color: #666; font-size: 0.8rem; }
</style>

<div class="page-header">
    <h1 class="page-title">Attendance</h1>
    <p class="page-subtitle">Track daily attendance with Nepali date</p>
</div>

@if (isAdminOrHR) {
    <div class="card mb-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
        <div class="card-body" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
            <div>
                <div style="font-size:0.8rem; opacity:0.9;">Pending Approvals</div>
                <div style="font-size:1.5rem; font-weight:bold;" id="pendingCount">0</div>
            </div>
            <div style="display:flex; gap:0.5rem;">
                <a href="/attendances/pending" class="btn" style="background:white; color:#667eea;">View All</a>
            </div>
        </div>
    </div>
}

<div class="card mb-3">
    <div class="card-body" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <div>
            <div style="font-size:0.8rem;color:var(--secondary);">Today</div>
            <div style="font-size:1.1rem;font-weight:600;" id="todayDateDisplay">--</div>
            <div style="font-size:0.75rem;color:var(--secondary);margin-top:0.25rem;" id="nepaliDateDisplay">--</div>
            <div style="font-size:0.75rem;color:var(--secondary);" id="locationDisplay"><i class="fas fa-map-marker-alt"></i> Detecting location...</div>
        </div>
        <div style="display:flex;align-items:center;gap:1rem;">
            <div style="text-align:center;">
                <div style="font-size:0.7rem;color:var(--secondary);">Clock In</div>
                <div style="font-size:1.1rem;font-weight:600;color:var(--success);" id="clockInTime">--:--</div>
            </div>
            <div style="text-align:center;">
                <div style="font-size:0.7rem;color:var(--secondary);">Clock Out</div>
                <div style="font-size:1.1rem;font-weight:600;color:var(--danger);" id="clockOutTime">--:--</div>
            </div>
            <div style="text-align:center;">
                <div style="font-size:0.7rem;color:var(--secondary);">Total Hours</div>
                <div style="font-size:1.1rem;font-weight:600;" id="totalHours">0h 0m</div>
            </div>
        </div>
        <div style="display:flex;gap:0.75rem;">
            <button class="btn-success" id="checkInBtn" onclick="clockIn()"><i class="fas fa-sign-in-alt"></i> Check In</button>
            <button class="btn-danger" id="checkOutBtn" onclick="clockOut()" disabled><i class="fas fa-sign-out-alt"></i> Check Out</button>
        </div>
    </div>
</div>

<div class="kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(160px,1fr));">
    <div class="kpi-card"><div class="kpi-icon green"><i class="fas fa-check"></i></div><div class="kpi-info"><div class="kpi-value" id="statPresent">0</div><div class="kpi-label">Present</div></div></div>
    <div class="kpi-card"><div class="kpi-icon red"><i class="fas fa-times"></i></div><div class="kpi-info"><div class="kpi-value" id="statAbsent">0</div><div class="kpi-label">Absent</div></div></div>
    <div class="kpi-card"><div class="kpi-icon orange"><i class="fas fa-clock"></i></div><div class="kpi-info"><div class="kpi-value" id="statLate">0</div><div class="kpi-label">Late/Pending</div></div></div>
    <div class="kpi-card"><div class="kpi-icon purple"><i class="fas fa-calendar-week"></i></div><div class="kpi-info"><div class="kpi-value" id="statWeekend">0</div><div class="kpi-label">Weekend</div></div></div>
    <div class="kpi-card"><div class="kpi-icon blue"><i class="fas fa-flag"></i></div><div class="kpi-info"><div class="kpi-value" id="statHoliday">0</div><div class="kpi-label">Holiday</div></div></div>
    <div class="kpi-card"><div class="kpi-icon teal"><i class="fas fa-hourglass-half"></i></div><div class="kpi-info"><div class="kpi-value" id="statHours">0h</div><div class="kpi-label">Total Hours</div></div></div>
</div>

<div class="table-container">
    <div class="table-header">
        <h3 style="font-size:1rem;font-weight:600;margin:0;">Attendance Records</h3>
        <div class="filter-bar">
            @if (isAdminOrHR) {
                <select id="employeeSelect" class="form-control">
                    <option value="">All Employees</option>
                </select>
            }
            <input type="date" class="form-control" id="dateFrom" />
            <input type="date" class="form-control" id="dateTo" />
            <label style="display:flex;align-items:center;gap:0.25rem;font-size:0.8rem;">
                <input type="checkbox" id="showWeekends" checked /> Weekends
            </label>
            <label style="display:flex;align-items:center;gap:0.25rem;font-size:0.8rem;">
                <input type="checkbox" id="showHolidays" checked /> Holidays
            </label>
            <button class="btn-secondary btn-sm" onclick="loadRecords()"><i class="fas fa-filter"></i> Filter</button>
            <button class="btn-success btn-sm" onclick="exportToExcel()"><i class="fas fa-file-excel"></i> Export</button>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Date (BS)</th>
                <th>Date (AD)</th>
                @if (isAdminOrHR) { <th>Employee</th> }
                <th>Clock In</th>
                <th>Clock Out</th>
                <th>Hours</th>
                <th>OT</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="attendanceBody">
            <tr><td colspan="9" class="text-center" style="padding:2rem;">Loading...</td></tr>
        </tbody>
    </table>
</div>

<div class="modal" id="approveModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
    <div class="modal-content" style="background:white; padding:2rem; border-radius:8px; max-width:500px; width:90%;">
        <h3 style="margin-top:0;">Approve/Reject Attendance</h3>
        <div id="modalContent"></div>
        <div style="margin-top:1rem; display:flex; gap:0.5rem; justify-content:flex-end;">
            <button class="btn-secondary" onclick="closeModal()">Cancel</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
var userLat = null, userLng = null, userLocation = 'Unknown';
var currentEmployeeId = null;
var isAdminOrHR = @(isAdminOrHR ? "true" : "false");
var currentUserId = '@User.Identity?.Name';

function showAlert(message, type = 'info') {
    const existingAlert = document.querySelector('.custom-alert');
    if (existingAlert) existingAlert.remove();
    
    const alertDiv = document.createElement('div');
    alertDiv.className = `custom-alert alert alert-${type} alert-dismissible fade show`;
    alertDiv.style.cssText = 'position:fixed; top:20px; right:20px; z-index:9999; min-width:300px;';
    alertDiv.innerHTML = `<i class="fas fa-${type === 'error' ? 'exclamation-circle' : type === 'warning' ? 'exclamation-triangle' : 'info-circle'} me-2"></i>${message}<button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>`;
    document.body.appendChild(alertDiv);
    setTimeout(() => { if (alertDiv.parentElement) alertDiv.remove(); }, 5000);
}

function getNepalDate(date) {
    var bsYear = date.getFullYear() - 56;
    var bsMonth = date.getMonth() + 1;
    var bsDay = date.getDate();
    if (date.getMonth() <= 2) bsMonth = date.getMonth() + 10;
    else bsMonth = date.getMonth() - 2;
    return bsYear + '/' + String(bsMonth).padStart(2, '0') + '/' + String(bsDay).padStart(2, '0');
}

function toNepalTime(dateStr) {
    if (!dateStr) return new Date();
    return new Date(dateStr + 'T00:00:00');
}

document.addEventListener('DOMContentLoaded', function() {
    var today = new Date();
    document.getElementById('todayDateDisplay').textContent = today.toLocaleDateString('en-US', {weekday:'long', year:'numeric', month:'long', day:'numeric'});
    document.getElementById('nepaliDateDisplay').textContent = 'BS: ' + getNepalDate(today);
    document.getElementById('dateFrom').value = new Date(today.getFullYear(), today.getMonth(), 1).toISOString().split('T')[0];
    document.getElementById('dateTo').value = today.toISOString().split('T')[0];

    getLocation();
    if (isAdminOrHR) {
        loadEmployees();
        loadPendingCount();
    }
    loadCurrentEmployee();
});

function loadPendingCount() {
    fetch('/api/attendance/pending').then(r => r.json()).then(data => {
        document.getElementById('pendingCount').textContent = data.length || 0;
    }).catch(() => {});
}

function loadEmployees() {
    fetch('/api/employee').then(r => r.json()).then(data => {
        var sel = document.getElementById('employeeSelect');
        if (data && data.length > 0 && sel) {
            data.forEach(e => {
                var opt = document.createElement('option');
                opt.value = e.id;
                opt.textContent = e.fullName || e.firstName + ' ' + e.lastName;
                sel.appendChild(opt);
            });
        }
    }).catch(err => console.error('Failed to load employees:', err));
}

function loadCurrentEmployee() {
    fetch('/api/employee/me').then(r => {
        if (!r.ok) { showAlert('Employee profile not found. Please contact admin.', 'error'); return null; }
        return r.json();
    }).then(data => {
        if (data && data.employee && data.employee.id) {
            currentEmployeeId = data.employee.id;
            loadTodayAttendance();
            loadRecords();
        }
    }).catch((error) => { console.error('Error loading employee:', error); });
}

function getLocation() {
    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(function(pos) {
            userLat = pos.coords.latitude;
            userLng = pos.coords.longitude;
            userLocation = userLat.toFixed(4) + ', ' + userLng.toFixed(4);
            document.getElementById('locationDisplay').innerHTML = '<i class="fas fa-map-marker-alt"></i> ' + userLocation;
        }, function() {
            document.getElementById('locationDisplay').innerHTML = '<i class="fas fa-map-marker-alt"></i> Location unavailable';
        });
    }
}

function loadTodayAttendance() {
    if (!currentEmployeeId) return;
    fetch('/api/attendance/today/' + currentEmployeeId).then(r => { if (!r.ok) return null; return r.json(); })
    .then(data => {
        const inVal = data.clockIn || data.clock_In;
        const outVal = data.clockOut || data.clock_Out;
        if (inVal) {
            document.getElementById('clockInTime').textContent = formatTime(inVal);
            document.getElementById('checkInBtn').disabled = true;
            document.getElementById('checkOutBtn').disabled = false;
            if (outVal) {
                document.getElementById('clockOutTime').textContent = formatTime(outVal);
                document.getElementById('checkOutBtn').disabled = true;
                document.getElementById('totalHours').textContent = (data.totalHours || 0).toFixed(1) + 'h';
            }
        }
    }).catch(() => {});
}

function clockIn() {
    if (!currentEmployeeId) { showAlert('Employee profile not found.', 'error'); return; }
    if (userLat === null || userLng === null) { showAlert('Location must be enabled to check-in.', 'warning'); return; }
    
    var body = { employeeId: currentEmployeeId, isLocationEnabled: true, latitude: userLat, longitude: userLng, locationAddress: userLocation };
    fetch('/api/attendance/clock-in', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
    .then(r => { if (r.ok) { loadTodayAttendance(); loadRecords(); showAlert('Checked in successfully!', 'success'); } else r.text().then(t => showAlert('Error: ' + t, 'error')); })
    .catch(() => showAlert('Failed to check in', 'error'));
}

function clockOut() {
    if (!currentEmployeeId) { showAlert('Employee profile not found.', 'error'); return; }
    var body = { employeeId: currentEmployeeId };
    fetch('/api/attendance/clock-out', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
    .then(r => { if (r.ok) { loadTodayAttendance(); loadRecords(); showAlert('Checked out successfully!', 'success'); } else r.text().then(t => showAlert('Error: ' + t, 'error')); })
    .catch(() => showAlert('Failed to check out', 'error'));
}

function loadRecords() {
    var from = document.getElementById('dateFrom').value;
    var to = document.getElementById('dateTo').value;
    var showWeekends = document.getElementById('showWeekends').checked;
    var showHolidays = document.getElementById('showHolidays').checked;
    
    var url = '/api/attendance?startDate=' + from + '&endDate=' + to + '&includeWeekends=' + showWeekends + '&includeHolidays=' + showHolidays;
    if (isAdminOrHR) {
        var empSel = document.getElementById('employeeSelect');
        if (empSel && empSel.value) url += '&employeeId=' + empSel.value;
    } else if (currentEmployeeId) {
        url += '&employeeId=' + currentEmployeeId;
    }
    
    fetch(url).then(r => { if (!r.ok) throw new Error('Failed'); return r.json(); })
    .then(data => { renderRecords(data); updateStats(data); })
    .catch(() => { document.getElementById('attendanceBody').innerHTML = '<tr><td colspan="9" class="text-center">No records found</td></tr>'; });
}

function renderRecords(data) {
    var tbody = document.getElementById('attendanceBody');
    if (!data || data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="9"><div class="empty-state"><i class="fas fa-clock"></i><h4>No records</h4></div></td></tr>';
        return;
    }
    
    tbody.innerHTML = data.map(a => {
        var status = a.status || 'Unknown';
        var rowClass = '';
        var badgeHtml = '';
        
        if (a.isHoliday) {
            rowClass = 'holiday-row';
            badgeHtml = '<span class="badge-holiday"><i class="fas fa-flag"></i> Holiday' + (a.holidayName ? ': ' + a.holidayName : '') + '</span>';
        } else if (a.isWeekend) {
            rowClass = 'weekend-row';
            badgeHtml = '<span class="badge-weekend"><i class="fas fa-calendar-week"></i> Weekend</span>';
        } else if (status === 'Pending') {
            rowClass = 'pending-row';
            badgeHtml = '<span class="badge-pending"><i class="fas fa-clock"></i> Pending Approval</span>';
        } else if (status === 'Present') {
            badgeHtml = '<span class="badge-status badge-success">Present</span>';
        } else if (status === 'Absent') {
            badgeHtml = '<span class="badge-status badge-danger">Absent</span>';
        } else if (status === 'OnLeave') {
            badgeHtml = '<span class="badge-status badge-info">On Leave</span>';
        } else {
            badgeHtml = '<span class="badge-status badge-warning">' + status + '</span>';
        }
        
        var clockIn = a.clockIn || a.clock_In;
        var clockOut = a.clockOut || a.clock_Out;
        var recordDate = a.date || a.Date;
        var nepalDate = a.nepaliDate || getNepalDate(new Date(recordDate));
        var dateDisplay = new Date(recordDate).toLocaleDateString();
        
        var actionHtml = '';
        if (isAdminOrHR && status === 'Pending') {
            actionHtml = '<button class="approve-btn btn-sm" onclick="approveAttendance(' + a.id + ')"><i class="fas fa-check"></i></button> ' +
                         '<button class="reject-btn btn-sm" onclick="rejectAttendance(' + a.id + ')"><i class="fas fa-times"></i></button>';
        }
        
        return '<tr class="' + rowClass + '">' +
            '<td class="nepali-date">' + nepalDate + '</td>' +
            '<td>' + dateDisplay + '</td>' +
            (isAdminOrHR ? '<td>' + (a.employeeName || '-') + '</td>' : '') +
            '<td>' + (clockIn ? formatTime(clockIn) : '-') + '</td>' +
            '<td>' + (clockOut ? formatTime(clockOut) : '-') + '</td>' +
            '<td>' + (a.totalHours ? a.totalHours.toFixed(1) + 'h' : '-') + '</td>' +
            '<td>' + ((a.oT_Hours || a.otHours) ? (a.oT_Hours || a.otHours).toFixed(1) + 'h' : '0') + '</td>' +
            '<td>' + badgeHtml + '</td>' +
            '<td>' + actionHtml + '</td>' +
        '</tr>';
    }).join('');
}

function updateStats(data) {
    if (!data) return;
    document.getElementById('statPresent').textContent = data.filter(a => a.status === 'Present').length;
    document.getElementById('statAbsent').textContent = data.filter(a => a.status === 'Absent').length;
    document.getElementById('statLate').textContent = data.filter(a => a.status === 'Pending').length;
    document.getElementById('statWeekend').textContent = data.filter(a => a.isWeekend).length;
    document.getElementById('statHoliday').textContent = data.filter(a => a.isHoliday).length;
    var totalH = data.reduce((s, a) => s + (a.totalHours || 0), 0);
    document.getElementById('statHours').textContent = totalH.toFixed(0) + 'h';
}

function formatTime(ts) {
    if (!ts || typeof ts !== 'string') return '--:--';
    const parts = ts.split(':');
    if (parts.length < 2) return ts;
    let h = parseInt(parts[0]);
    let m = parts[1];
    if (isNaN(h)) return '--:--';
    const ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12 || 12;
    return `${h.toString().padStart(2, '0')}:${m} ${ampm}`;
}

function approveAttendance(id) {
    if (!confirm('Approve this attendance record?')) return;
    fetch('/api/attendance/approve/' + id, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ approvedBy: currentUserId || 'Admin', remarks: 'Approved' })
    }).then(r => { if (r.ok) { showAlert('Attendance approved!', 'success'); loadRecords(); loadPendingCount(); } else showAlert('Failed to approve', 'error'); });
}

function rejectAttendance(id) {
    if (!confirm('Reject this attendance record?')) return;
    fetch('/api/attendance/reject/' + id, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ rejectedBy: currentUserId || 'Admin', remarks: 'Rejected' })
    }).then(r => { if (r.ok) { showAlert('Attendance rejected!', 'success'); loadRecords(); loadPendingCount(); } else showAlert('Failed to reject', 'error'); });
}

function closeModal() { document.getElementById('approveModal').style.display = 'none'; }

function exportToExcel() {
    var from = document.getElementById('dateFrom').value;
    var to = document.getElementById('dateTo').value;
    var showWeekends = document.getElementById('showWeekends').checked;
    var showHolidays = document.getElementById('showHolidays').checked;
    
    var url = '/api/attendance/export?startDate=' + from + '&endDate=' + to + '&includeWeekends=' + showWeekends + '&includeHolidays=' + showHolidays;
    if (isAdminOrHR) {
        var empSel = document.getElementById('employeeSelect');
        if (empSel && empSel.value) url += '&employeeId=' + empSel.value;
    } else if (currentEmployeeId) {
        url += '&employeeId=' + currentEmployeeId;
    }
    window.open(url, '_blank');
}
</script>
}
