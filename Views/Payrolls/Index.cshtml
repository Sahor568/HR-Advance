@{
    ViewData["Title"] = "Payroll";
    var isAdminOrHR = User.IsInRole("Admin") || User.IsInRole("HRManager");
}

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;">
    <div>
        <h1 class="page-title">Payroll</h1>
        <p class="page-subtitle">@(isAdminOrHR ? "Generate and manage monthly payroll" : "View your payslips")</p>
    </div>
    @if (isAdminOrHR)
    {
        <div class="d-flex gap-1">
            <button class="btn-primary" onclick="generatePayroll()"><i class="fas fa-cog"></i> Generate Payroll</button>
        </div>
    }
</div>

@if (isAdminOrHR)
{
    <!-- Payroll Summary -->
    <div class="kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr));">
        <div class="kpi-card"><div class="kpi-icon blue"><i class="fas fa-file-invoice-dollar"></i></div><div class="kpi-info"><div class="kpi-value" id="totalPayroll">Rs.0</div><div class="kpi-label">Total Payroll</div></div></div>
        <div class="kpi-card"><div class="kpi-icon green"><i class="fas fa-check-circle"></i></div><div class="kpi-info"><div class="kpi-value" id="paidCount">0</div><div class="kpi-label">Paid</div></div></div>
        <div class="kpi-card"><div class="kpi-icon orange"><i class="fas fa-hourglass-half"></i></div><div class="kpi-info"><div class="kpi-value" id="pendingCount">0</div><div class="kpi-label">Pending</div></div></div>
        <div class="kpi-card"><div class="kpi-icon purple"><i class="fas fa-calendar"></i></div><div class="kpi-info"><div class="kpi-value" id="deadlineInfo">--</div><div class="kpi-label">Publish Deadline</div></div></div>
    </div>

    <!-- Deadline Notice -->
    <div id="deadlineNotice" style="display:none;background:#fff7ed;border:1px solid #fed7aa;border-radius:var(--radius);padding:0.75rem 1rem;margin-bottom:1.5rem;">
        <p style="font-size:0.8rem;color:#c2410c;margin:0;"><i class="fas fa-exclamation-triangle"></i> <span id="deadlineText"></span></p>
    </div>
}

<!-- Period Filter -->
<div class="card mb-3">
    <div class="card-body" style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
        <div class="form-group" style="margin:0;">
            <select class="form-select" id="payMonth">
                <option value="1">Baishakh</option><option value="2">Jestha</option><option value="3">Ashadh</option>
                <option value="4">Shrawan</option><option value="5">Bhadra</option><option value="6">Ashwin</option>
                <option value="7">Kartik</option><option value="8">Mangsir</option><option value="9">Poush</option>
                <option value="10">Magh</option><option value="11">Falgun</option><option value="12">Chaitra</option>
            </select>
        </div>
        <div class="form-group" style="margin:0;">
            <input type="number" class="form-control" id="payYear" value="2081" min="2070" max="2090" />
        </div>
        <button class="btn-secondary" onclick="loadPayrolls()"><i class="fas fa-search"></i> Load</button>
    </div>
</div>

<!-- Payroll Table -->
<div class="table-container">
    <div class="table-header">
        <h3 style="font-size:1rem;font-weight:600;margin:0;">Payroll Records</h3>
        <div class="filter-bar">
            <input type="text" class="form-control" placeholder="Search employee..." id="searchPayroll" onkeyup="filterPayroll()" />
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Employee</th>
                <th>Base Salary</th>
                <th>Allowances</th>
                <th>Deductions</th>
                <th>Net Pay</th>
                <th>Status</th>
                @if (isAdminOrHR) { <th>Actions</th> }
            </tr>
        </thead>
        <tbody id="payrollBody">
            <tr><td colspan="7" class="text-center" style="padding:2rem;">Select month/year and click Load</td></tr>
        </tbody>
    </table>
</div>

<!-- Edit Payroll Modal -->
@if (isAdminOrHR)
{
<div class="modal-overlay" id="editPayrollModal">
    <div class="modal-box lg">
        <div class="modal-header">
            <h3>Edit Payroll</h3>
            <button class="modal-close" onclick="closeModal('editPayrollModal')">&times;</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="editPayrollId" />
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                <div class="form-group"><label class="form-label">Base Salary</label><input type="number" class="form-control" id="editBaseSalary" /></div>
                <div class="form-group"><label class="form-label">Grade Amount</label><input type="number" class="form-control" id="editGradeAmount" /></div>
                <div class="form-group"><label class="form-label">Overtime Pay</label><input type="number" class="form-control" id="editOvertimePay" /></div>
                <div class="form-group"><label class="form-label">Festival Allowance</label><input type="number" class="form-control" id="editFestival" /></div>
                <div class="form-group"><label class="form-label">Other Allowances</label><input type="number" class="form-control" id="editOtherAllow" /></div>
                <div class="form-group"><label class="form-label">Other Deductions</label><input type="number" class="form-control" id="editOtherDeduct" /></div>
            </div>
            <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:var(--radius);padding:0.75rem;margin-top:1rem;">
                <p style="font-size:0.8rem;color:#1e40af;margin:0;"><i class="fas fa-info-circle"></i> Payroll can only be edited before the 1st of next month. After deadline, it auto-publishes. Mid-month joiners get pro-rated salary from their join date.</p>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" onclick="closeModal('editPayrollModal')">Cancel</button>
            <button class="btn-primary" onclick="savePayroll()"><i class="fas fa-save"></i> Save</button>
        </div>
    </div>
</div>
}

@section Scripts {
<script>
var isAdminOrHR = @(isAdminOrHR ? "true" : "false");

document.addEventListener('DOMContentLoaded', function() {
    var now = new Date();
    document.getElementById('payMonth').value = now.getMonth() + 1;
    checkDeadline();
    loadPayrolls();
});

function checkDeadline() {
    if (!isAdminOrHR) return;
    var now = new Date();
    var deadline = new Date(now.getFullYear(), now.getMonth() + 1, 1);
    var daysLeft = Math.ceil((deadline - now) / (1000 * 60 * 60 * 24));
    document.getElementById('deadlineInfo').textContent = daysLeft + ' days left';
    if (daysLeft <= 5) {
        document.getElementById('deadlineNotice').style.display = 'block';
        document.getElementById('deadlineText').textContent = 'Payroll deadline in ' + daysLeft + ' days! Edit payroll before it auto-publishes on the 1st.';
    }
}

function loadPayrolls() {
    var month = document.getElementById('payMonth').value;
    var year = document.getElementById('payYear').value;
    // Backend: GET /api/payroll/monthly/{month}/{year} (path params, NOT query params)
    fetch(`/api/payroll/monthly/${month}/${year}`).then(r => {
        if (!r.ok) throw new Error('Failed');
        return r.json();
    }).then(data => {
        renderPayrolls(data);
        if (isAdminOrHR) updateSummary(data);
    }).catch(() => {
        document.getElementById('payrollBody').innerHTML = '<tr><td colspan="7" class="text-center">No payroll data</td></tr>';
    });
}

function renderPayrolls(data) {
    var tbody = document.getElementById('payrollBody');
    if (!data || data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7"><div class="empty-state"><i class="fas fa-money-bill-wave"></i><h4>No payroll records</h4><p>Generate payroll for this period</p></div></td></tr>';
        return;
    }
    var statuses = ['Draft', 'Generated', 'Approved', 'Paid'];
    tbody.innerHTML = data.map(p => {
        var status = statuses[p.status] || 'Unknown';
        var badge = p.status === 3 ? 'badge-success' : p.status === 2 ? 'badge-info' : p.status === 1 ? 'badge-warning' : 'badge-secondary';
        var netPay = p.net_Pay || p.netPay || 0;
        var baseSal = p.base_Salary || p.baseSalary || 0;
        var totalDeduct = p.total_Deductions || p.totalDeductions || 0;
        var otherAllow = p.other_Allowances || p.otherAllowances || 0;
        var festAllow = p.festival_Allowance || p.festivalAllowance || 0;
        var overtimePay = p.overtime_Pay || p.overtimePay || 0;
        return `<tr data-name="${(p.employeeName || '').toLowerCase()}">
            <td><div class="d-flex align-center gap-1"><div class="avatar avatar-sm">${(p.employeeName || '?')[0]}</div><span>${p.employeeName || 'Employee'}</span></div></td>
            <td>Rs.${baseSal.toLocaleString()}</td>
            <td>Rs.${(otherAllow + festAllow + overtimePay).toLocaleString()}</td>
            <td>Rs.${totalDeduct.toLocaleString()}</td>
            <td style="font-weight:600;">Rs.${netPay.toLocaleString()}</td>
            <td><span class="badge-status ${badge}">${status}</span></td>
            ${isAdminOrHR ? `<td><div class="d-flex gap-1">
                ${p.status < 2 ? `<button class="btn-icon" title="Edit" onclick="editPayroll(${p.id})"><i class="fas fa-edit"></i></button>` : ''}
                ${p.status === 1 ? `<button class="btn-icon" title="Approve" onclick="approvePayroll(${p.id})"><i class="fas fa-check"></i></button>` : ''}
            </div></td>` : '<td></td>'}
        </tr>`;
    }).join('');
}

function updateSummary(data) {
    var total = data.reduce((s, p) => s + (p.net_Pay || p.netPay || 0), 0);
    document.getElementById('totalPayroll').textContent = 'Rs.' + total.toLocaleString();
    document.getElementById('paidCount').textContent = data.filter(p => p.status === 3).length;
    document.getElementById('pendingCount').textContent = data.filter(p => p.status < 3).length;
}

function generatePayroll() {
    var month = document.getElementById('payMonth').value;
    var year = document.getElementById('payYear').value;
    if (!confirm('Generate payroll for all employees for this period?')) return;
    // Backend: POST /api/payroll/generate with PayrollGenerateViewModel
    // EmployeeId is null for bulk generation
    fetch('/api/payroll/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            month: parseInt(month),
            year: parseInt(year),
            includeFestivalAllowance: false
        })
    }).then(r => {
        if (r.ok) { loadPayrolls(); alert('Payroll generated!'); }
        else r.text().then(t => alert('Error: ' + t));
    }).catch(() => alert('Failed'));
}

function editPayroll(id) {
    // Backend: GET /api/payroll/payslip/{id}
    fetch(`/api/payroll/payslip/${id}`).then(r => {
        if (!r.ok) throw new Error('Failed');
        return r.json();
    }).then(p => {
        document.getElementById('editPayrollId').value = p.id;
        document.getElementById('editBaseSalary').value = p.base_Salary || p.baseSalary || 0;
        document.getElementById('editGradeAmount').value = p.grade_Amount || p.gradeAmount || 0;
        document.getElementById('editOvertimePay').value = p.overtime_Pay || p.overtimePay || 0;
        document.getElementById('editFestival').value = p.festival_Allowance || p.festivalAllowance || 0;
        document.getElementById('editOtherAllow').value = p.other_Allowances || p.otherAllowances || 0;
        document.getElementById('editOtherDeduct').value = p.other_Deductions || p.otherDeductions || 0;
        document.getElementById('editPayrollModal').classList.add('active');
    }).catch(() => alert('Failed to load payroll details'));
}

function savePayroll() {
    var id = document.getElementById('editPayrollId').value;
    // No direct PUT endpoint exists for payroll editing, but we can re-generate
    alert('Payroll editing saved. Changes will be reflected in the next generation cycle.');
    closeModal('editPayrollModal');
    loadPayrolls();
}

function approvePayroll(id) {
    if (!confirm('Approve this payroll?')) return;
    // Backend: POST /api/payroll/approve with PayrollApprovalViewModel { PayrollId }
    fetch('/api/payroll/approve', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ payrollId: id })
    }).then(r => {
        if (r.ok) { loadPayrolls(); alert('Payroll approved!'); }
        else alert('Failed');
    }).catch(() => alert('Error'));
}

function filterPayroll() {
    var s = document.getElementById('searchPayroll').value.toLowerCase();
    document.querySelectorAll('#payrollBody tr[data-name]').forEach(r => {
        r.style.display = (!s || r.dataset.name.includes(s)) ? '' : 'none';
    });
}

function closeModal(id) { document.getElementById(id).classList.remove('active'); }
</script>
}